    course="florarium"
  />

  {/* ===== FAQ ===== */}
  <section id="faq" class="relative bg-white px-[10px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    <img src="/images/masterclass/decor-wreath-1.webp" alt="" width="200" height="200"
      class="hidden lg:block absolute pointer-events-none z-0 decor-sway"
      style="top: 4%; right: -1%; width: 150px; height: auto; opacity: 0.55; --dur: 8s; --del: -4s;" />
    <img src="/images/masterclass/decor-leaf-1.webp" alt="" width="160" height="180"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="bottom: 5%; left: -1%; width: 120px; height: auto; opacity: 0.6; --dur: 7s; --del: -2s;" />
    <div class="max-w-[1280px] mx-auto">
      <div class="flex justify-center mb-[20px] reveal">
        <img
          src="/images/masterclass/faq-title.webp"
          alt="Питання та відповідь"
          width="1024"
          height="460"
          class="w-full max-w-[280px] md:max-w-[380px] lg:max-w-[420px] h-auto"
          loading="lazy"
        />
      </div>
      <FaqAccordion faqs={faqs} />
    </div>
  </section>

</MasterclassLayout>

<style is:global>
  .florarium-float {
    animation: florariumBob 4s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes florariumBob {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-14px); }
  }

  /* Curriculum image hover zoom */
  .curriculum-img {
    transition: transform 0.4s ease;
    will-change: transform;
  }
  .curriculum-img:hover {
    transform: scale(1.04);
  }

  /* ===== Decorative botanical element animations ===== */
  @keyframes decorFloat {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  @keyframes decorSway {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    33% { transform: translateY(-7px) rotate(2deg); }
    66% { transform: translateY(-11px) rotate(-1.5deg); }
  }
  @keyframes decorFloatMirror {
    0%, 100% { transform: scaleX(-1) translateY(0px); }
    50% { transform: scaleX(-1) translateY(-10px); }
  }

  .decor-anim {
    animation: decorFloat var(--dur, 7s) ease-in-out var(--del, 0s) infinite;
    will-change: transform;
  }
  .decor-sway {
    animation: decorSway var(--dur, 7s) ease-in-out var(--del, 0s) infinite;
    will-change: transform;
  }
  .decor-anim-mirror {
    animation: decorFloatMirror var(--dur, 7s) ease-in-out var(--del, 0s) infinite;
    will-change: transform;
  }

  /* ===== Curriculum vertical timeline line ===== */
  .curriculum-timeline {
    --timeline-bottom: 420px; /* height of lesson 4 image + margin, line stops at circle 4 */
  }
  .curriculum-timeline::before {
    content: '';
    position: absolute;
    left: 32px; /* 14px padding + 18px (center of 36px circle) */
    top: 18px;
    bottom: var(--timeline-bottom);
    width: 1px;
    background: #d9d9d9;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .curriculum-timeline::before {
      left: 18px;
    }
  }

  /* ===== Product image slide-in animations ===== */
  .included-slide-left {
    transform: translateX(-60px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  .included-slide-left.revealed {
    transform: translateX(0);
  }
  .included-slide-right {
    transform: translateX(60px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    transition-delay: 0.15s;
  }
  .included-slide-right.revealed {
    transform: translateX(0);
  }

  /* ===== Animated lightbulb glow ===== */
  .bulb-glow {
    filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.4));
  }
  .bulb-ray {
    animation: bulbRayPulse 2s ease-in-out infinite;
  }
  .bulb-ray:nth-child(2) { animation-delay: 0.15s; }
  .bulb-ray:nth-child(3) { animation-delay: 0.3s; }
  .bulb-ray:nth-child(4) { animation-delay: 0.45s; }
  .bulb-ray:nth-child(5) { animation-delay: 0.6s; }
  @keyframes bulbRayPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  /* ===== Hero text fade-in from top (matching main hero slide-up) ===== */
  .hero-text-fade {
    opacity: 0;
    animation: heroTextFadeIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes heroTextFadeIn {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== Hero zigzag underline animation (stroke-dashoffset draw) ===== */
  .hero-zigzag-path {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    opacity: 0;
    animation: heroZigzagDraw 1s cubic-bezier(0.4, 0, 0.2, 1) 0.6s forwards;
  }
  @keyframes heroZigzagDraw {
    to {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }

  /* ===== Daria slide-up from bottom ===== */
  .hero-daria-slide {
    opacity: 0;
    animation: heroDecorSlideIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
    --slide-x: 0px;
    --slide-y: 40px;
  }

  /* ===== Hero decorative slide-in animation (matching main hero) ===== */
  @keyframes heroDecorSlideIn {
    from {
      opacity: 0;
      transform: translate(var(--slide-x, 0), var(--slide-y, 0));
    }
    to {
      opacity: 1;
      transform: translate(0, 0);
    }
  }
  .hero-decor-slide {
    opacity: 0;
    animation: heroDecorSlideIn 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* ===== Hotspot buttons (pink pulsing circles with white +) ===== */
  .florarium-hotspot-container {
    position: relative;
  }
  .hotspot-btn {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #F3237D;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: transform 0.2s ease;
  }
  .hotspot-btn:hover {
    transform: translate(-50%, -50%) scale(1.15);
  }
  /* Ripple pulse animation */
  .hotspot-btn::before,
  .hotspot-btn::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    display: block;
    border: 1px solid rgba(243, 35, 125, 0.5);
    border-radius: 50%;
    animation: hotspot-ripple 2.6s cubic-bezier(0.25, 0.9, 0.2, 1) infinite;
  }
  .hotspot-btn::before {
    width: 140%;
    height: 140%;
    border-color: rgba(243, 35, 125, 0.6);
  }
  .hotspot-btn::after {
    width: 100%;
    height: 100%;
    border-color: rgba(243, 35, 125, 0.4);
    animation-delay: 0.4s;
  }
  @keyframes hotspot-ripple {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    100% { transform: translate(-50%, -50%) scale(1.7); opacity: 0; }
  }

  /* Tooltip */
  .hotspot-btn .hotspot-tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) scale(0.9);
    background: #003B1C;
    color: white;
    font-family: 'Tenor Sans', serif;
    font-size: 14px;
    padding: 6px 14px;
    border-radius: 8px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 20;
  }
  .hotspot-btn .hotspot-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: #003B1C;
  }
  .hotspot-btn.active .hotspot-tooltip {
    opacity: 1;
    transform: translateX(-50%) scale(1);
    pointer-events: auto;
  }

  /* ===== Animated green highlight underline for "Флораріум" ===== */
  .highlight-path {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    opacity: 0;
    transition: stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease-out;
    transition-delay: 0.3s;
  }
  .revealed .highlight-path,
  .reveal.revealed .highlight-path {
    stroke-dashoffset: 0;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .decor-anim, .decor-sway, .decor-anim-mirror {
      animation: none !important;
    }
    .hotspot-btn::before, .hotspot-btn::after {
      animation: none !important;
    }
    .highlight-path {
      stroke-dashoffset: 0 !important;
      opacity: 1 !important;
      transition: none !important;
    }
  }
</style>

<script>
  // Hotspot tooltip toggle on click
  document.querySelectorAll('.hotspot-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasActive = btn.classList.contains('active');
      document.querySelectorAll('.hotspot-btn.active').forEach(b => b.classList.remove('active'));
      if (!wasActive) btn.classList.add('active');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.hotspot-btn.active').forEach(b => b.classList.remove('active'));
  });
</script>
