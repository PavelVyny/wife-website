---
import MasterclassLayout from '../layouts/MasterclassLayout.astro';
import MasterclassHero from '../components/MasterclassHero.astro';
import TargetAudienceSection from '../components/TargetAudienceSection.astro';
import EducationalBlock from '../components/EducationalBlock.astro';
import WhatsIncludedSection from '../components/WhatsIncludedSection.astro';
import PricingCta from '../components/PricingCta.astro';
import LearningOutcomes from '../components/LearningOutcomes.astro';
import InstructorSection from '../components/InstructorSection.astro';
import ValueProps from '../components/ValueProps.astro';
import CurriculumSection from '../components/CurriculumSection.astro';
import CtaButton from '../components/CtaButton.astro';
import FaqSection from '../components/FaqSection.astro';

const PURCHASE_URL = 'https://secure.wayforpay.com/payment/sb10851d18b99';

const valueCards = [
  {
    title: "Знання, які не знайти на YouTube",
    description: "Я ділюся перевіреними секретами та порадами, які напрацювала за роки роботи. Ви отримаєте чіткий план створення флораріуму — без здогадок, помилок і марно витраченого часу",
    image: "/images/masterclass/value-memoji-1.webp",
  },
  {
    title: "Покроковий алгоритм",
    description: "Я покажу кожен етап створення — від вибору матеріалів до догляду за композицією. Вам не доведеться шукати додаткову інформацію, усе вже зібрано для вас!",
    image: "/images/masterclass/value-memoji-2.webp",
  },
  {
    title: "Економія часу та грошей",
    description: "Вам не потрібно переглядати десятки відео в пошуках потрібної інформації. Ви отримаєте все і одразу в структурованому вигляді, який легко застосувати на практиці",
    image: "/images/masterclass/value-memoji-3.webp",
  },
];

const faqs = [
  {
    q: 'Що я отримаю після проходження майстер-класу?',
    a: [
      'Ви створите свій унікальний флораріум, який прикрасить ваш дім або стане чудовим подарунком для близьких.',
      'Дізнаєтеся, як правильно вибрати та закупити матеріали.',
      'Отримаєте покрокові інструкції зі створення флораріуму.',
      'Навчитеся доглядати за флораріумом, щоб він залишався гарним тривалий час.',
      'Усі відео залишаються у вас у доступі, щоб ви могли працювати у своєму темпі.',
    ],
  },
  {
    q: 'Де проходить навчання?',
    a: [
      'Навчання проходить повністю онлайн: 4 відеоуроки у записі будуть розміщені на YouTube.',
      'Ви отримаєте доступ до всіх матеріалів через Telegram-канал, що дуже зручно!',
      'Ви можете дивитися уроки в будь-який час і з будь-якого пристрою.',
    ],
  },
  {
    q: 'Як можна оплатити майстер-клас?',
    a: ['Оплату можна здійснити через банківський переказ на ФОП-рахунок.'],
  },
  {
    q: 'Чи можу я навчатися, якщо ніколи не працював із рослинами?',
    a: ['Так, майстер-клас розрахований навіть на початківців. Я все детально пояснюю у відео, тому вам не знадобляться попередні знання.'],
  },
  {
    q: 'Скільки часу потрібно на створення флораріуму?',
    a: [
      'Ви можете працювати у своєму темпі. Для кожного уроку потрібно приблизно 30–60 хвилин, плюс час для закупівлі матеріалів.',
      'Усі уроки доступні в записі, тому ви можете розподілити час так, як вам зручно.',
    ],
  },
  {
    q: 'Скільки коштує закупка матеріалів?',
    a: [
      'Вартість залежить від того, які матеріали ви оберете: який декор та елементи захочете додати, яку скляну вазу або форму виберете для флораріуму.',
      'У середньому закупівля матеріалів для одного флораріуму обійдеться приблизно у 700–1000 грн.',
      'При цьому частина матеріалів, як-от декор, залишиться, і ви зможете використовувати їх для наступних робіт.',
    ],
  },
  {
    q: 'Чи потрібно мати спеціальні інструменти або матеріали?',
    a: ['Усе необхідне легко знайти в магазинах або замовити онлайн. У першому уроці я розповім, що саме вам знадобиться і де це можна придбати.'],
  },
  {
    q: 'Чи є обмеження за часом доступу до відеоуроків?',
    a: ['Ні, доступ до відео не обмежений. Ви можете повертатися до матеріалів у будь-який час.'],
  },
  {
    q: 'Що робити, якщо у мене виникнуть питання під час навчання?',
    a: ['Якщо у вас з\'являться питання, ви завжди можете написати мені через Instagram, і я із задоволенням допоможу.'],
  },
  {
    q: 'Чи можна подарувати цей майстер-клас іншій людині?',
    a: ['Так, звісно! Це чудовий подарунок для тих, хто любить творчість. Просто повідомте мене, і я оформлю доступ для вашого друга чи близького.'],
  },
];

const heroDecorElements = [
  { src: "/images/masterclass/hero/decor-cookie-1.webp", width: 213, height: 215, visibility: "mobile-only" as const, style: "top: 10%; left: 2%; width: 42px; height: auto; --slide-x: -80px; --slide-y: -40px; animation-delay: 0.3s;" },
  { src: "/images/masterclass/hero/decor-cookie-3.webp", width: 200, height: 185, visibility: "tablet-down" as const, style: "top: 64%; right: 2%; width: 42px; height: auto; --slide-x: 80px; --slide-y: 20px; animation-delay: 0.6s;" },
  { src: "/images/masterclass/hero/decor-plant-pot.webp", width: 280, height: 310, visibility: "mobile-only" as const, style: "top: 60%; left: 4%; width: 56px; height: auto; --slide-x: -60px; --slide-y: 80px; animation-delay: 0.4s;" },
  { src: "/images/masterclass/hero/decor-small-plant.webp", width: 200, height: 250, visibility: "tablet-down" as const, style: "top: 10%; right: 0%; width: 50px; height: auto; --slide-x: 100px; --slide-y: -60px; animation-delay: 0.35s;" },
  { src: "/images/masterclass/hero/decor-succulent.webp", width: 213, height: 215, visibility: "desktop-only" as const, style: "top: 56%; right: 0%; width: 55px; height: auto; --slide-x: 100px; --slide-y: 20px; animation-delay: 0.3s;" },
  { src: "/images/masterclass/hero/decor-green-3.webp", width: 162, height: 202, visibility: "desktop-only" as const, style: "top: 14%; right: 0%; width: 80px; height: auto; --slide-x: 100px; --slide-y: -40px; animation-delay: 0.3s;" },
];

const audienceCards = [
  {
    image: "/images/masterclass/audience-beginners.webp",
    imageAlt: "Новачки та початківці",
    title: "Новачки та початківці",
    description: "Цей майстер-клас чудово підійде для тих, хто ніколи не працював із рослинами чи декоративними композиціями. Ви навчитесь базовим технікам створення флораріумів у легкій та доступній формі",
  },
  {
    image: "/images/masterclass/audience-decor.webp",
    imageAlt: "Шанувальники декору",
    title: "Шанувальники декору",
    description: "Ідеальний вибір для тих, хто обожнює створювати стильний декор для дому. Флораріум додасть затишку вашому простору та стане прекрасним елементом новорічного настрою",
  },
  {
    image: "/images/masterclass/audience-inspiration.webp",
    imageAlt: "Ті, хто шукає натхнення",
    title: "Ті, хто шукає натхнення",
    description: "Для креативних особистостей, які люблять постійно генерувати нові ідеї, майстер-клас стане джерелом натхнення та простором для творчого самовираження",
  },
  {
    image: "/images/masterclass/audience-gifts.webp",
    imageAlt: "Любителі подарунків",
    title: "Любителі подарунків",
    description: "Якщо ви хочете створити щось унікальне своїми руками, щоб подарувати рідним або друзям, цей майстер-клас точно для вас. Флораріум стане символом уваги та турботи",
  },
];

const educationalHotspots = [
  { label: "Живі сукуленти", left: "50%", top: "39%" },
  { label: "Стабілізований мох", left: "16%", top: "38%" },
  { label: "Декоративні камінці", left: "28%", top: "60%" },
  { label: "Кольоровий пісок", left: "74%", top: "74%" },
  { label: "Грунт і керамзит", left: "55%", top: "90%" },
  { label: "Скляна форма", left: "80%", top: "17%" },
];

const educationalBenefits = [
  "Стильний декор для дому чи офісу",
  "Особливий подарунок для близьких",
  "Спосіб додати природної краси у ваше життя",
];

const includedItems = [
  "Повний список матеріалів із зазначенням, де їх купити (з посиланнями на магазини)",
  "Три детальні відео з покроковими інструкціями",
];

const learningItems = [
  "Ви створите стильний флораріум своїми руками",
  "Додасте до свого інтер'єру затишку",
  "Зробите незвичайний подарунок для близьких, створений власноруч",
  "Зможете почати свій творчий шлях у флористиці або ж отримати натхнення для хобі",
];

const curriculumLessons = [
  {
    title: "Підготовка",
    titleRest: "та закупівля матеріалів",
    description: "Список усіх необхідних матеріалів, перелік магазинів, корисні поради щодо вибору компонентів",
    imageMobile: "/images/masterclass/curriculum-lesson-1.webp",
    imageDesktop: "/images/masterclass/curriculum-lesson-1.webp",
    imageAlt: "Підготовка та закупівля матеріалів",
  },
  {
    title: "Створення",
    titleRest: "флораріуму",
    description: "Детальна покрокова інструкція зі створення флораріуму в геометричній скляній вазі",
    imageMobile: "/images/masterclass/curriculum-lesson-2.webp",
    imageDesktop: "/images/masterclass/curriculum-lesson-2.webp",
    imageAlt: "Створення флораріуму",
  },
  {
    title: "Догляд",
    titleRest: "за флораріумом",
    description: "Як доглядати за флораріумом, щоб він залишався свіжим та гарним максимально довго",
    imageMobile: "/images/masterclass/curriculum-lesson-3.webp",
    imageDesktop: "/images/masterclass/curriculum-lesson-3.webp",
    imageAlt: "Догляд за флораріумом",
  },
  {
    title: "Композиція",
    titleRest: "в бетонному кашпо",
    description: "Створення мініатюрної святкової композиції для декору столу або на подарунок",
    imageMobile: "/images/masterclass/curriculum-lesson-4.webp",
    imageDesktop: "/images/masterclass/curriculum-lesson-4.webp",
    imageAlt: "Композиція в бетонному кашпо",
  },
];
---

<MasterclassLayout
  title="Створення флораріуму — Floralab Education"
  description="Покроковий онлайн майстер-клас зі створення живого флораріуму у скляній вазі. 4 відеоуроки від експерта-флориста."
  currentPath="/stvorennya-florariumu"
  purchaseUrl={PURCHASE_URL}
  purchaseLabel="Придбати навчання"
>

  <MasterclassHero
    heroId="florarium-hero"
    bgMobile="/images/hero-bg-moss.webp"
    bgDesktop="/images/hero-bg-desktop.webp"
    dariaImg="/images/masterclass/hero/daria-florarium.webp"
    dariaAlt="Даша з флораріумом"
    dariaWidth={1035}
    dariaHeight={1067}
    badgeText="Онлайн майстер-клас"
    titleLine1="Створення"
    titleLine2="флораріуму"
    subtitle="Онлайн навчання зі створення<br class='md:hidden' /> ексклюзивних композицій з<br class='md:hidden' /> сукулентів у скляних вазах"
    ctaText="Дізнатися більше"
    ctaHref="#pricing"
    decorElements={heroDecorElements}
    bleedElement={{ src: "/images/masterclass/hero/decor-cookie-2.webp", width: 200, height: 200, style: "bottom: -40px; left: 2%; height: auto; filter: brightness(100%) contrast(100%) saturate(75%) blur(5.3px) hue-rotate(0deg); --slide-x: -60px; --slide-y: 100px; animation-delay: 0.15s; width: 88px;" }}
  />

  <TargetAudienceSection
    titleImage="/images/masterclass/for-who-title.webp"
    titleImageAlt="Для кого цей майстер-клас"
    subtitle="Цей майстер-клас для тих, хто мріє додати затишку в інтер'єр, створити щось особливе своїми руками та втілити власні творчі ідеї!"
    cards={audienceCards}
    decorRightImage="/images/masterclass/decor-right-plant.webp"
  />

  <EducationalBlock
    titleImage="/images/masterclass/what-is-florarium-title.webp"
    titleImageAlt="Що таке флораріум?"
    headingHighlight="Флораріум"
    headingRest="— це унікальна мініатюрна багаторічна композиція з живих рослин, створена у скляній ємності"
    productImage="/images/masterclass/florarium-product.webp"
    productImageAlt="Що таке флораріум — гексагональна ілюстрація"
    productImageWidth={560}
    productImageHeight={540}
    hotspots={educationalHotspots}
    benefits={educationalBenefits}
    quoteImage="/images/masterclass/quote-bubble.webp"
    quoteImageAlt="Це не просто рослини у горщику — це маленький живий світ, який ви створюєте власноруч!"
    memojiImage="/images/masterclass/daria-memoji.webp"
  />

  <WhatsIncludedSection
    titleImage="/images/masterclass/whats-included-title.webp"
    titleImageAlt="Що входить у майстер-клас"
    items={includedItems}
    bonusItem="Відео-урок по створенню композиції в бетонному кашпо"
    productImg1="/images/masterclass/florarium-included-1.webp"
    productImg1Alt="Флораріум — що входить у майстер-клас"
    productImg2="/images/masterclass/florarium-included-2.webp"
    productImg2Alt="Композиція в бетонному кашпо"
    decorMossImage="/images/masterclass/decor-moss-ball.webp"
    bleedCookieImage="/images/masterclass/decor-cookie-blur.webp"
    bleedCookieStyle="bottom: -15px; left: 20%; width: 65px; height: auto; filter: brightness(107%) contrast(100%) saturate(71%) blur(6.7px) hue-rotate(0deg);"
  />

  <PricingCta
    price="450 грн"
    originalPrice="1500 грн"
    ctaText="Придбати зараз"
    purchaseUrl={PURCHASE_URL}
    course="florarium"
  />

  <LearningOutcomes
    titleImage="/images/masterclass/results-title.webp"
    items={learningItems}
    img1="/images/masterclass/results-img-1.webp"
    img1Alt="Результати — флораріум"
    img2="/images/masterclass/results-img-2.webp"
    img2Alt="Результати — композиція"
    topDecorImage="/images/masterclass/decor-cookie-blur.webp"
    topDecorStyle="top: 30px; right: 50px; width: 50px; height: auto; filter: brightness(100%) contrast(100%) saturate(73%) blur(0) hue-rotate(0deg);"
  />

  <InstructorSection />

  <ValueProps cards={valueCards} />

  <CurriculumSection
    titleImage="/images/masterclass/curriculum-title.webp"
    titleImageAlt="Програма майстер-класу"
    lessons={curriculumLessons}
    layout="zigzag"
    timelineClass="curriculum-timeline"
    decorImage="/images/masterclass/decor-fern-1.webp"
    decorStyle="top: 8%; left: -1.5%; width: 145px; height: auto; opacity: 0.75; --dur: 8s; --del: -1s;"
  />

  <CtaButton />

  <FaqSection
    titleImage="/images/masterclass/faq-title.webp"
    faqs={faqs}
    decorTopRight={{ src: "/images/masterclass/decor-pot-plant.webp", style: "top: 4%; right: calc(-1% + 20px); width: 100px; height: auto; opacity: 0.55;" }}
    decorBottomLeft={{ src: "/images/masterclass/decor-leaf-1.webp", style: "bottom: 5%; left: -1%; width: 120px; height: auto; opacity: 0.6; --dur: 7s; --del: -2s;" }}
  />

</MasterclassLayout>

<style is:global>
  .florarium-float {
    animation: florariumBob 4s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes florariumBob {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-14px); }
  }



  @media (prefers-reduced-motion: reduce) {
    .florarium-float { animation: none !important; }
  }
</style>
