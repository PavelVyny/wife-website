---
import MasterclassLayout from '../layouts/MasterclassLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import InstructorSection from '../components/InstructorSection.astro';
import ValueProps from '../components/ValueProps.astro';
import PricingCta from '../components/PricingCta.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BotanicalElement from '../components/BotanicalElement.astro';
import { Image } from 'astro:assets';
import florariumProduct from '../assets/masterclass/florarium-product.webp';

const PURCHASE_URL = 'https://secure.wayforpay.com/payment/sb10851d18b99';

const valueCards = [
  {
    title: "Знання, які не знайти на YouTube",
    description: "Я ділюся перевіреними секретами та порадами, які напрацювала за роки роботи. Ви отримаєте чіткий план створення флораріуму — без здогадок, помилок і марно витраченого часу",
    image: "/images/masterclass/value-memoji-1.webp",
  },
  {
    title: "Покроковий алгоритм",
    description: "Я покажу кожен етап створення — від вибору матеріалів до догляду за композицією. Вам не доведеться шукати додаткову інформацію, усе вже зібрано для вас!",
    image: "/images/masterclass/value-memoji-2.webp",
  },
  {
    title: "Економія часу та грошей",
    description: "Вам не потрібно переглядати десятки відео в пошуках потрібної інформації. Ви отримаєте все і одразу в структурованому вигляді, який легко застосувати на практиці",
    image: "/images/masterclass/value-memoji-3.webp",
  },
];

const faqs = [
  {
    q: 'Що я отримаю після проходження майстер-класу?',
    a: [
      'Ви створите свій унікальний флораріум, який прикрасить ваш дім або стане чудовим подарунком для близьких.',
      'Дізнаєтеся, як правильно вибрати та закупити матеріали.',
      'Отримаєте покрокові інструкції зі створення флораріуму.',
      'Навчитеся доглядати за флораріумом, щоб він залишався гарним тривалий час.',
      'Усі відео залишаються у вас у доступі, щоб ви могли працювати у своєму темпі.',
    ],
  },
  {
    q: 'Де проходить навчання?',
    a: [
      'Навчання проходить повністю онлайн: 4 відеоуроки у записі будуть розміщені на YouTube.',
      'Ви отримаєте доступ до всіх матеріалів через Telegram-канал, що дуже зручно!',
      'Ви можете дивитися уроки в будь-який час і з будь-якого пристрою.',
    ],
  },
  {
    q: 'Як можна оплатити майстер-клас?',
    a: ['Оплату можна здійснити через банківський переказ на ФОП-рахунок.'],
  },
  {
    q: 'Чи можу я навчатися, якщо ніколи не працював із рослинами?',
    a: ['Так, майстер-клас розрахований навіть на початківців. Я все детально пояснюю у відео, тому вам не знадобляться попередні знання.'],
  },
  {
    q: 'Скільки часу потрібно на створення флораріуму?',
    a: [
      'Ви можете працювати у своєму темпі. Для кожного уроку потрібно приблизно 30–60 хвилин, плюс час для закупівлі матеріалів.',
      'Усі уроки доступні в записі, тому ви можете розподілити час так, як вам зручно.',
    ],
  },
  {
    q: 'Скільки коштує закупка матеріалів?',
    a: [
      'Вартість залежить від того, які матеріали ви оберете: який декор та елементи захочете додати, яку скляну вазу або форму виберете для флораріуму.',
      'У середньому закупівля матеріалів для одного флораріуму обійдеться приблизно у 700–1000 грн.',
      'При цьому частина матеріалів, як-от декор, залишиться, і ви зможете використовувати їх для наступних робіт.',
    ],
  },
  {
    q: 'Чи потрібно мати спеціальні інструменти або матеріали?',
    a: ['Усе необхідне легко знайти в магазинах або замовити онлайн. У першому уроці я розповім, що саме вам знадобиться і де це можна придбати.'],
  },
  {
    q: 'Чи є обмеження за часом доступу до відеоуроків?',
    a: ['Ні, доступ до відео не обмежений. Ви можете повертатися до матеріалів у будь-який час.'],
  },
  {
    q: 'Що робити, якщо у мене виникнуть питання під час навчання?',
    a: ['Якщо у вас з\'являться питання, ви завжди можете написати мені через Instagram, і я із задоволенням допоможу.'],
  },
  {
    q: 'Чи можна подарувати цей майстер-клас іншій людині?',
    a: ['Так, звісно! Це чудовий подарунок для тих, хто любить творчість. Просто повідомте мене, і я оформлю доступ для вашого друга чи близького.'],
  },
];
---

<MasterclassLayout
  title="Створення флораріуму — Floralab Education"
  description="Покроковий онлайн майстер-клас зі створення живого флораріуму у скляній вазі. 4 відеоуроки від експерта-флориста."
  currentPath="/stvorennya-florariumu"
  purchaseUrl={PURCHASE_URL}
  purchaseLabel="Придбати навчання"
>

  {/* ===== HERO ===== */}
  {/* Wrapper for hero + blurred cookie that bleeds below */}
  <div class="relative">
  <section
    id="florarium-hero"
    class="relative overflow-hidden rounded-b-[25px]"
    style="background: #f8f8f8 url('/images/masterclass/hero/hero-bg-original.webp') no-repeat 0% 0%/cover;"
  >
    {/* Daria — desktop: absolutely positioned, right half */}
    <div
      class="hidden lg:block absolute inset-y-0 pointer-events-none z-0"
      style="left: 44%; right: -80px;"
    >
      <img
        src="/images/masterclass/hero/daria-florarium.webp"
        alt=""
        width="1035"
        height="1067"
        class="h-full w-auto object-contain object-bottom"
        loading="eager"
      />
    </div>

    {/* Mobile decorative images — slide-in animations matching main hero */}
    {/* Top-left cookie — slides from left */}
    <img src="/images/masterclass/hero/decor-cookie-1.webp" alt="" width="213" height="215"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide"
      style="top: 28%; left: 2%; width: 42px; height: auto; --slide-x: -80px; --slide-y: -40px; animation-delay: 0.3s;" />
    {/* Small cookie left (near Daria) — slides from left */}
    <img src="/images/masterclass/hero/decor-cookie-2.webp" alt="" width="200" height="200"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide"
      style="top: 58%; left: 2%; width: 42px; height: auto; --slide-x: -80px; --slide-y: 20px; animation-delay: 0.5s;" />
    {/* Cookie right — slides from right */}
    <img src="/images/masterclass/hero/decor-cookie-3.webp" alt="" width="200" height="185"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide"
      style="top: 64%; right: 2%; width: 42px; height: auto; --slide-x: 80px; --slide-y: 20px; animation-delay: 0.6s;" />
    {/* Plant with pot — slides from bottom-left, moved up */}
    <img src="/images/masterclass/hero/decor-plant-pot.webp" alt="" width="280" height="310"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide"
      style="top: 64%; left: 8%; width: 84px; height: auto; --slide-x: -60px; --slide-y: 80px; animation-delay: 0.4s;" />
    {/* Small plant top-right — slides from right */}
    <img src="/images/masterclass/hero/decor-small-plant.webp" alt="" width="200" height="250"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide"
      style="top: 30%; right: 0%; width: 50px; height: auto; --slide-x: 100px; --slide-y: -60px; animation-delay: 0.35s;" />

    {/* Content */}
    <div class="relative">
      <div
        class="max-w-[1280px] mx-auto px-6 md:px-8 relative z-10 pt-[60px] md:pt-[80px] lg:pt-[200px] pb-[20px] lg:pb-[80px]"
      >
        <div class="max-w-[600px] lg:max-w-[540px] mx-auto lg:mx-0 text-center lg:text-left">

          {/* Badge — fade in from top, smaller matching original ~206x32 */}
          <div class="flex justify-center lg:justify-start mb-8 hero-text-fade" style="animation-delay: 0s;">
            <div
              class="inline-flex items-center gap-[8px] rounded-full"
              style="background: #00401E; padding: 7px 16px;"
            >
              <span style="font-size: 14px; line-height: 1; display: inline-block; transform: rotate(15deg);">⭐</span>
              <span class="font-heading text-white font-medium" style="font-size: 14px; line-height: 1;">Онлайн майстер-клас</span>
            </div>
          </div>

          {/* Title — fade in from top */}
          <h1 class="font-heading text-black uppercase mb-7 hero-text-fade" style="line-height: 1.08; letter-spacing: -0.36px; animation-delay: 0.1s;">
            <span class="block text-[38px] md:text-[68px] lg:text-[89px]">Створення</span>
            <span class="relative inline-block text-[38px] md:text-[68px] lg:text-[89px]">
              флораріуму
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 500 150"
                class="absolute -bottom-1 left-0 w-full h-8 overflow-visible pointer-events-none"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <path
                  class="hero-zigzag-path"
                  d="M9.3,127.3c49.3-3,150.7-7.6,199.7-7.4c121.9,0.4,189.9,0.4,282.3,7.2C380.1,129.6,181.2,130.6,70,139 c82.6-2.9,254.2-1,335.9,1.3c-56,1.4-137.2-0.3-197.1,9"
                  fill="none"
                  stroke="#7fac00"
                  stroke-width="28"
                  stroke-linecap="round"
                />
              </svg>
            </span>
          </h1>

          {/* Subtitle — fade in from top */}
          <p class="font-heading text-black mb-8 mx-auto lg:mx-0 hero-text-fade" style="font-size: 16px; line-height: 24px; max-width: 340px; animation-delay: 0.2s;">
            Онлайн навчання зі створення<br class="md:hidden" />
            ексклюзивних композицій з<br class="md:hidden" />
            сукулентів у скляних вазах
          </p>

          {/* CTA — fade in from top */}
          <div class="flex justify-center lg:justify-start hero-text-fade" style="animation-delay: 0.3s;">
            <a
              href={PURCHASE_URL}
              class="inline-flex items-center justify-center font-heading text-white font-medium hover:scale-[1.02] transition-transform"
              style="padding: 16px 30px; background: #F3237D; border-radius: 100px; font-size: 18px;"
            >
              Придбати зараз
            </a>
          </div>
        </div>

        {/* Mobile: Daria — 10px from right screen edge, slides up from bottom */}
        <div class="lg:hidden mt-6 flex justify-end relative z-[6] hero-daria-slide"
          style="margin-bottom: -40px; margin-right: -14px;"
        >
          <img
            src="/images/masterclass/hero/daria-florarium.webp"
            alt="Даша з флораріумом"
            width="661"
            height="1019"
            class="w-full max-w-[232px]"
            loading="eager"
          />
        </div>
      </div>
    </div>

    {/* Floating botanical decor — desktop only */}
    <img src="/images/masterclass/hero/decor-green-1.webp" alt="" width="227" height="212"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 40%; left: 53.5%; width: 62px; height: auto; --dur: 6s; --del: -1s;" />
    <img src="/images/masterclass/hero/decor-green-2.webp" alt="" width="227" height="212"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 62%; right: -1%; width: 85px; height: auto; --dur: 7.5s; --del: -3s;" />
    <img src="/images/masterclass/hero/decor-green-3.webp" alt="" width="162" height="202"
      class="hidden lg:block absolute pointer-events-none z-0 decor-sway"
      style="top: 14%; right: 10%; width: 102px; height: auto; --dur: 8s; --del: -2s;" />
    <img src="/images/masterclass/hero/decor-succulent.webp" alt="" width="213" height="215"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="bottom: 22%; left: 27%; width: 53px; height: auto; --dur: 5.5s; --del: -4s;" />
    <img src="/images/masterclass/hero/decor-pink-moss.webp" alt="" width="200" height="180"
      class="hidden lg:block absolute pointer-events-none z-0 decor-sway"
      style="top: 5%; right: 2%; width: 120px; height: auto; --dur: 7s; --del: -3.5s;" />
    <img src="/images/masterclass/hero/decor-ball.webp" alt="" width="120" height="120"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 52%; left: 42%; width: 48px; height: auto; --dur: 5s; --del: -1.5s;" />
  </section>

  {/* Blurred cookie — bleeds below hero section */}
  <img src="/images/masterclass/hero/decor-cookie-2.webp" alt="" width="200" height="200"
    class="lg:hidden absolute pointer-events-none z-[1] hero-decor-slide"
    style="bottom: -60px; left: 2%; width: 132px; height: auto; filter: brightness(100%) contrast(100%) saturate(75%) blur(5.3px) hue-rotate(0deg); --slide-x: -60px; --slide-y: 100px; animation-delay: 0.15s;" />
  </div>

  {/* ===== TARGET AUDIENCE ===== */}
  <section class="relative bg-white px-[10px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    {/* Decorative elements — matching originals exact positions */}
    <img src="/images/masterclass/decor-herb-cluster.webp" alt="" width="280" height="268"
      class="hidden lg:block absolute pointer-events-none z-0 decor-sway"
      style="top: 5%; left: -3%; width: 210px; height: auto; opacity: 0.9; filter: blur(1px); --dur: 7s; --del: -2s;" />
    <img src="/images/masterclass/decor-right-plant.webp" alt="" width="929" height="906"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 2%; right: 1%; width: 160px; height: auto; --dur: 6s; --del: -1s;" />

    <div class="max-w-[1280px] mx-auto relative z-10">
      <div class="flex justify-center mb-[8px] reveal">
        <img
          src="/images/masterclass/for-who-title.webp"
          alt="Для кого цей майстер-клас"
          width="1024"
          height="460"
          class="w-full max-w-[300px] md:max-w-[400px] lg:max-w-[460px] h-auto"
          loading="lazy"
        />
      </div>
      <p class="text-brand-dark/70 text-[16px] md:text-[18px] leading-[28px] text-center mb-[40px] max-w-[780px] mx-auto reveal">
        Цей майстер-клас для тих, хто мріє додати затишку в інтер'єр, створити щось особливе своїми руками та втілити власні творчі ідеї!
      </p>

      {/* 2×2 grid — image left, text right */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px] md:gap-[20px]">

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-beginners.webp" alt="Новачки та початківці"
            width="800" height="783"
            class="flex-shrink-0 w-[200px] h-[200px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Новачки та початківці</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Цей майстер-клас чудово підійде для тих, хто ніколи не працював із рослинами чи декоративними композиціями. Ви навчитесь базовим технікам створення флораріумів у легкій та доступній формі</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-decor.webp" alt="Шанувальники декору"
            width="800" height="783"
            class="flex-shrink-0 w-[200px] h-[200px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Шанувальники декору</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Ідеальний вибір для тих, хто обожнює створювати стильний декор для дому. Флораріум додасть затишку вашому простору та стане прекрасним елементом новорічного настрою</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-inspiration.webp" alt="Ті, хто шукає натхнення"
            width="800" height="783"
            class="flex-shrink-0 w-[200px] h-[200px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Ті, хто шукає натхнення</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Для креативних особистостей, які люблять постійно генерувати нові ідеї, майстер-клас стане джерелом натхнення та простором для творчого самовираження</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-gifts.webp" alt="Любителі подарунків"
            width="800" height="783"
            class="flex-shrink-0 w-[200px] h-[200px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-brand-dark text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Любителі подарунків</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Якщо ви хочете створити щось унікальне своїми руками, щоб подарувати рідним або друзям, цей майстер-клас точно для вас. Флораріум стане символом уваги та турботи</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ===== WHAT IS A FLORARIUM ("ЩО ТАКЕ ФЛОРАРІУМ?") ===== */}
  <section class="relative bg-white px-[10px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] lg:pb-[120px] overflow-hidden">
    <img src="/images/masterclass/decor-leaf-3.webp" alt="" width="180" height="200"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 12%; left: -1.5%; width: 130px; height: auto; opacity: 0.8; --dur: 7s; --del: -3s;" />
    <img src="/images/masterclass/decor-fern-2.webp" alt="" width="200" height="220"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim-mirror"
      style="bottom: 8%; right: -1%; width: 140px; height: auto; opacity: 0.75; --dur: 8s; --del: -1.5s;" />
    <div class="max-w-[1280px] mx-auto relative z-10">

      {/* Title banner — original image with decorative flowers */}
      <div class="flex justify-center mb-[16px] md:mb-[24px] reveal">
        <img
          src="/images/masterclass/what-is-florarium-title.webp"
          alt="Що таке флораріум?"
          width="1024"
          height="506"
          class="w-full max-w-[320px] md:max-w-[420px] lg:max-w-[500px] h-auto"
          loading="lazy"
        />
      </div>

      {/* Desktop: 2 columns — text left, benefits right */}
      <div class="lg:grid lg:grid-cols-2 lg:gap-[48px] lg:items-start mt-[8px] lg:mt-[24px]">

        {/* Left column: heading text with animated highlight */}
        <div class="reveal">
          <h2 class="font-heading text-black text-[22px] md:text-[36px] lg:text-[50px] leading-[1.25] text-center lg:text-left mb-[24px] lg:mb-0">
            <span class="relative inline">
              <span class="relative z-10 font-heading">Флораріум </span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 500 150"
