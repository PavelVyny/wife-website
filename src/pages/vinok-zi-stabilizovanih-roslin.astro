---
import MasterclassLayout from '../layouts/MasterclassLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import InstructorSection from '../components/InstructorSection.astro';
import ValueProps from '../components/ValueProps.astro';
import PricingCta from '../components/PricingCta.astro';

const PURCHASE_URL = 'https://secure.wayforpay.com/payment/s9517959b27ff'; // TODO: update with real vinok payment URL

const valueCards = [
  {
    title: "Знання, які не знайти на YouTube",
    description: "Я ділюся перевіреними секретами та порадами, які напрацювала за роки роботи. Ви отримаєте чіткий план створення вінка — без здогадок, помилок і марно витраченого часу",
    image: "/images/masterclass/value-memoji-1.webp",
  },
  {
    title: "Покроковий алгоритм",
    description: "Я покажу кожен етап створення — від вибору матеріалів до догляду за композицією. Вам не доведеться шукати додаткову інформацію, усе вже зібрано для вас!",
    image: "/images/masterclass/value-memoji-2.webp",
  },
  {
    title: "Економія часу та грошей",
    description: "Вам не потрібно переглядати десятки відео в пошуках потрібної інформації. Ви отримаєте все і одразу в структурованому вигляді, який легко застосувати на практиці",
    image: "/images/masterclass/value-memoji-3.webp",
  },
];


const faqs = [
  {
    q: 'Що я отримаю після проходження майстер-класу?',
    a: [
      'Ви створите власний вінок зі стабілізованих рослин, який стане стильним акцентом вашого інтер\'єру або особливим подарунком.',
      'Навчитеся: правильно підбирати матеріали, працювати з текстурами та кольорами, будувати гармонійну композицію, надійно фіксувати елементи.',
      'Отримаєте чітку систему роботи замість хаотичних спроб.',
      'Усі уроки залишаються у вас у доступі, тому ви зможете повертатися до них у будь-який момент.',
    ],
  },
  {
    q: 'Де проходить навчання?',
    a: [
      'Навчання повністю онлайн. Ви отримуєте 3 відеоуроки у записі, доступ через закритий Telegram-канал.',
      'Можливість переглядати матеріали у зручному темпі, доступ з будь-якого пристрою.',
    ],
  },
  {
    q: 'Як можна оплатити майстер-клас?',
    a: ['Оплату можна здійснити через банківський переказ на ФОП-рахунок.'],
  },
  {
    q: 'Чи можу я навчатися, якщо ніколи не працював із рослинами?',
    a: [
      'Так. Майстер-клас розрахований навіть на новачків.',
      'У першому уроці ми детально розбираємо теорію, матеріали та інструменти. Пояснення подані простою мовою — без складних професійних термінів.',
    ],
  },
  {
    q: 'Скільки часу потрібно на створення вінка?',
    a: [
      'Кожен урок триває приблизно 30–60 хвилин. Практичну частину ви можете виконувати у зручному темпі.',
      'У середньому на створення вінка йде 2–4 години (без урахування закупівлі матеріалів).',
      'Усі уроки доступні у записі, тому ви можете розподілити процес так, як вам зручно.',
    ],
  },
  {
    q: 'Скільки коштує закупівля матеріалів?',
    a: [
      'Вартість залежить від розміру майбутнього вінка, вибраної основи, кількості та виду рослин, додаткових декоративних елементів.',
      'У середньому закупівля матеріалів для одного вінка становить 1500–2000 грн.',
      'Частина матеріалів залишиться у вас, і ви зможете використовувати їх для наступних робіт.',
    ],
  },
  {
    q: 'Чи потрібно мати спеціальні інструменти або матеріали?',
    a: ['Ні. Більшість інструментів — прості та доступні. Я надаю повний список необхідних матеріалів і посилання на магазини, де їх можна придбати.'],
  },
  {
    q: 'Чи є обмеження за часом доступу до відеоуроків?',
    a: ['Ні, доступ до відео не обмежений. Ви можете повертатися до матеріалів у будь-який час.'],
  },
  {
    q: 'Що робити, якщо у мене виникнуть питання під час навчання?',
    a: ['Якщо у вас з\'являться питання, ви завжди можете написати мені через Instagram, і я із задоволенням допоможу.'],
  },
  {
    q: 'Чи можна подарувати цей майстер-клас іншій людині?',
    a: ['Так, звісно! Це чудовий подарунок для тих, хто любить творчість. Просто повідомте мене, і я оформлю доступ для вашого друга чи близького.'],
  },
];
---

<MasterclassLayout
  title="Вінок зі стабілізованих рослин — Floralab Education"
  description="Покроковий онлайн майстер-клас зі створення декоративного вінка зі стабілізованих рослин. Без поливу та догляду."
  currentPath="/vinok-zi-stabilizovanih-roslin"
  purchaseUrl={PURCHASE_URL}
  purchaseLabel="Придбати навчання"
>

  {/* ===== HERO ===== */}
  <div class="relative">
  <section
    id="vinok-hero"
    class="relative overflow-hidden rounded-b-[25px] lg:mt-[-90px]"
    style="background: #f8f8f8 url('/images/masterclass-vinok/hero/hero-bg.webp') no-repeat 0% 0%/cover;"
  >
    {/* Mobile decorative images — positions matched from original */}
    {/* Top-left: green moss ball — 16% top, 4% left, 53px */}
    <img src="/images/masterclass-vinok/hero/decor-5.webp" alt="" width="200" height="200"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide-k"
      style="top: 16%; left: 4%; width: 53px; height: auto; --slide-x: -80px; --slide-y: -40px; animation-delay: 0.3s;" />
    {/* Right of description: cotton/white piece — 37% top, 85% left, 49px */}
    <img src="/images/masterclass-vinok/hero/decor-2.webp" alt="" width="200" height="200"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide-k"
      style="top: 37%; left: 85%; width: 49px; height: auto; --slide-x: 80px; --slide-y: -20px; animation-delay: 0.35s;" />
    {/* Left mid: brown piece — 55% top, 12% left, 59px */}
    <img src="/images/masterclass-vinok/hero/decor-3.webp" alt="" width="200" height="200"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide-k"
      style="top: 55%; left: 12%; width: 59px; height: auto; --slide-x: -100px; --slide-y: 20px; animation-delay: 0.4s;" />
    {/* Right below CTA: tiny green — 65% top, 88% left, 31px */}
    <img src="/images/masterclass-vinok/hero/decor-4.webp" alt="" width="200" height="200"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide-k"
      style="top: 65%; left: 88%; width: 31px; height: auto; --slide-x: 60px; --slide-y: 10px; animation-delay: 0.5s;" />
    {/* Right mid: large bark/branch — 53% top, 64% left, 159px */}
    <img src="/images/masterclass-vinok/hero/decor-6.webp" alt="" width="200" height="200"
      class="lg:hidden absolute pointer-events-none z-[5] hero-decor-slide-k"
      style="top: 53%; left: 64%; width: 159px; height: auto; --slide-x: 100px; --slide-y: 40px; animation-delay: 0.45s;" />

    {/* Content */}
    <div class="relative">
      <div
        class="max-w-[1280px] mx-auto px-6 md:px-8 relative z-10 pt-[60px] md:pt-[80px] lg:pt-[290px] pb-[20px] lg:pb-[80px]"
      >
        <div class="max-w-[600px] lg:max-w-[540px] mx-auto lg:mx-0 text-center lg:text-left">

          {/* Badge */}
          <div class="flex justify-center lg:justify-start mb-8 hero-text-fade-k" style="animation-delay: 0.1s;">
            <div class="inline-flex items-center gap-2 bg-[#003B1C] text-white font-heading text-[14px] px-5 py-2 rounded-full shadow-md">
              <img src="/images/masterclass/star_2b50.webp" alt="" width="14" height="14" class="w-[14px] h-[14px]" style="transform: rotate(15deg);" />
              Онлайн майстер-клас
            </div>
          </div>

          {/* Title with zigzag under ВІНОК */}
          <h1 class="font-heading text-brand-dark text-[32px] md:text-[42px] lg:text-[56px] leading-[1.1] mb-5 hero-text-fade-k" style="animation-delay: 0.2s;">
            <span class="relative inline-block">ВІНОК
              <svg class="absolute left-0 w-full highlight-path" style="bottom: 2px; height: 12px; z-index: -1;" viewBox="0 0 500 150" preserveAspectRatio="none">
                <path d="M14.4,111.6c0,0,202.9-33.7,471.2,0c0,0-194-8.9-397.3,24.7c0,0,141.9-5.9,309.2,0"
                  fill="none" stroke="#a5d100" stroke-width="42" stroke-linecap="round"/>
              </svg>
            </span> ЗІ<br/>СТАБІЛІЗОВАНИХ<br/>РОСЛИН
          </h1>

          {/* Description */}
          <p class="text-brand-dark/80 text-[16px] md:text-[18px] leading-[28px] mb-7 hero-text-fade-k" style="animation-delay: 0.3s;">
            Навчіться створювати стильний<br/>
            декоративний вінок для інтер'єру —<br/>
            без складних технік та досвіду
          </p>

          {/* CTA */}
          <div class="flex justify-center lg:justify-start hero-text-fade-k" style="animation-delay: 0.35s;">
            <a
              href={PURCHASE_URL}
              data-course="wreath"
              data-buy-now-cta
              class="kartini-cta-btn inline-flex items-center justify-center px-[40px] py-[16px] bg-[#E63380] text-white rounded-full font-heading text-[20px] md:text-[22px]"
            >
              Придбати зараз
            </a>
          </div>
        </div>
      </div>

      {/* Daria mobile */}
      <div class="lg:hidden flex justify-center mt-[-20px] relative z-[2] hero-daria-slide-k">
        <img
          src="/images/masterclass-vinok/hero/daria-vinok.webp"
          alt="Дар'я з вінком зі стабілізованих рослин"
          width="600"
          height="673"
          class="w-[80%] max-w-[320px] h-auto object-contain"
          loading="eager"
        />
      </div>
    </div>
  </section>

  {/* Bottom large moss ball — bleeds below hero, 132px, partially visible */}
  <img src="/images/masterclass-vinok/hero/decor-1.webp" alt="" width="200" height="200"
    class="lg:hidden absolute pointer-events-none z-[6] hero-decor-slide-k"
    style="bottom: -40px; left: 7%; width: 132px; height: auto; --slide-x: -60px; --slide-y: 80px; animation-delay: 0.55s;" />
  </div>

  {/* ===== TARGET AUDIENCE ===== */}
  <section class="relative bg-white px-[10px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    {/* Decorative elements */}
    <img src="/images/masterclass/decor-herb-cluster.webp" alt="" width="280" height="268"
      class="hidden lg:block absolute pointer-events-none z-0 decor-sway"
      style="top: 5%; left: -3%; width: 210px; height: auto; opacity: 0.9; filter: blur(1px); --dur: 7s; --del: -2s;" />
    <img src="/images/masterclass/decor-right-plant.webp" alt="" width="929" height="906"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 2%; right: 1%; width: 160px; height: auto; --dur: 6s; --del: -1s;" />

    <div class="max-w-[1280px] mx-auto relative z-10">
      {/* Title image */}
      <div class="flex justify-center mb-[8px] reveal">
        <img
          src="/images/masterclass-vinok/for-who-title.webp"
          alt="Для кого цей майстер-клас"
          width="1024"
          height="460"
          class="w-full max-w-[320px] md:max-w-[420px] lg:max-w-[460px] h-auto"
          loading="lazy"
        />
      </div>
      <p class="text-brand-dark/70 text-[16px] md:text-[18px] leading-[28px] text-center mb-[40px] max-w-[780px] mx-auto reveal">
        Цей майстер-клас для тих, хто хоче створити стильний природний декор своїми руками, додати затишку в інтер'єр і спробувати новий формат творчості без складнощів і спеціальної підготовки
      </p>

      {/* 2×2 grid — image left, text right */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px] md:gap-[20px]">

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass-vinok/audience-beginners.webp" alt="Новачки та початківці"
            width="800" height="800"
            class="flex-shrink-0 w-[220px] h-[220px] md:w-[260px] md:h-[260px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Новачки та початківці</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Ідеально підійде тим, хто ніколи не працював зі стабілізованими рослинами. Ви отримаєте базові знання про матеріали, принципи побудови композиції, правила поєднання кольорів, підходящий алгоритм створення вінка</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass-vinok/audience-decor.webp" alt="Шанувальники декору"
            width="800" height="800"
            class="flex-shrink-0 w-[220px] h-[220px] md:w-[260px] md:h-[260px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Шанувальники декору</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Ідеальний формат для тих, хто любить стильні деталі в інтер'єрі. Вінок зі стабілізованих рослин не потребує поливу та догляду, але при цьому має вигляд живого, дорогого та прикрашає кожен простір</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass-vinok/audience-inspiration.webp" alt="Ті, хто шукає натхнення"
            width="800" height="800"
            class="flex-shrink-0 w-[220px] h-[220px] md:w-[260px] md:h-[260px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Ті, хто шукає натхнення</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Майстер-клас стане простором для творчого перезавантаження. Робота з природними текстурами чудово знімає стрес, допомагає відволіктись та дає задоволення від створеного результату</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass-vinok/audience-gifts.webp" alt="Любителі подарунків"
            width="800" height="800"
            class="flex-shrink-0 w-[220px] h-[220px] md:w-[260px] md:h-[260px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Любителі подарунків</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Вінок, створений власноруч, — це особливий подарунок. Ви зможете зробити унікальну річ для близьких, створити декор на замовлення або подарувати собі новий творчий досвід</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ===== WHAT ARE STABILIZED PLANTS ===== */}
  <section class="relative bg-white px-[10px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    <div class="max-w-[1280px] mx-auto relative z-10">

      {/* Title image */}
      <div class="flex justify-center mb-[16px] reveal">
        <img
          src="/images/masterclass-vinok/what-is-title.webp"
          alt="Що таке стабілізовані рослини?"
          width="1024"
          height="482"
          class="w-full max-w-[320px] md:max-w-[420px] lg:max-w-[460px] h-auto"
          loading="lazy"
        />
      </div>

      {/* Description with highlighted word */}
      <div class="text-center mb-[24px] reveal">
        <h2 class="font-heading text-[#003B1C] text-[22px] md:text-[26px] leading-[1.4]">
          <span class="relative inline-block">Стабілізовані рослини
            <svg class="absolute left-0 w-full highlight-path" style="bottom: 2px; height: 10px; z-index: -1;" viewBox="0 0 500 150" preserveAspectRatio="none">
              <path d="M14.4,111.6c0,0,202.9-33.7,471.2,0c0,0-194-8.9-397.3,24.7c0,0,141.9-5.9,309.2,0"
                fill="none" stroke="#a5d100" stroke-width="90" stroke-linecap="round"/>
            </svg>
          </span>— це натуральні рослини, які пройшли спеціальну обробку та зберегли свою форму, текстуру і колір
        </h2>
      </div>

      {/* Product image with hotspots */}
      <div class="flex justify-center mb-[32px] reveal">
        <div class="relative inline-block florarium-hotspot-container" style="width: 90%; max-width: 420px;">
          <img
            src="/images/masterclass-vinok/stabilized-product.webp"
            alt="Вінок зі стабілізованих рослин з позначеними елементами"
            width="900"
            height="817"
            class="w-full h-auto rounded-[20px]"
            loading="lazy"
          />
          <button class="hotspot-btn" style="left: 83.5%; top: 20.8%;" aria-label="Дерев'яна основа">
            <span class="text-white text-[16px] font-bold leading-none">+</span>
            <span class="hotspot-tooltip">Дерев'яна основа</span>
          </button>
          <button class="hotspot-btn" style="left: 33.5%; top: 22.8%;" aria-label="Ягель зелений">
            <span class="text-white text-[16px] font-bold leading-none">+</span>
            <span class="hotspot-tooltip">Ягель зелений</span>
          </button>
          <button class="hotspot-btn" style="left: 69.5%; top: 45.8%;" aria-label="Коряга">
            <span class="text-white text-[16px] font-bold leading-none">+</span>
            <span class="hotspot-tooltip">Коряга</span>
          </button>
          <button class="hotspot-btn" style="left: 23.5%; top: 55.8%;" aria-label="Амарант">
            <span class="text-white text-[16px] font-bold leading-none">+</span>
            <span class="hotspot-tooltip">Амарант</span>
          </button>
          <button class="hotspot-btn" style="left: 60.5%; top: 77.8%;" aria-label="Плоский мох">
            <span class="text-white text-[16px] font-bold leading-none">+</span>
            <span class="hotspot-tooltip">Плоский мох</span>
          </button>
        </div>
      </div>

      {/* Benefit list with checkmarks */}
      <div class="reveal">
        <ul class="space-y-[20px] px-[14px] md:px-0">
          {[
            "Не потребують догляду",
            "Не в'януть",
            "Не потребують світла",
            "Зберігають вигляд роками",
            "Поєднують натуральність та практичність",
          ].map((item) => (
            <li class="text-black text-[18px] leading-[28px] flex gap-[12px] items-center font-heading font-medium">
              <span class="flex-shrink-0 w-[28px] h-[28px] rounded-full flex items-center justify-center" style="background: #7fac00;">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {item}
            </li>
          ))}
