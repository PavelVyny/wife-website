  },
  {
    title: "Огляд матеріалів",
    titleRest: "та побудова композиції",
    bullets: [
      "Інструменти для роботи",
      "Варіанти основи для вінка",
      "Різновиди стабілізованих рослин",
      "Підготовка елементів до монтажу",
      "Техніка безпеки",
    ],
    imageMobile: "/images/masterclass-vinok/curriculum-2.webp",
    imageDesktop: "/images/masterclass-vinok/curriculum-2.webp",
    imageAlt: "Огляд матеріалів та побудова композиції",
  },
  {
    title: "Покрокове створення",
    titleRest: "вінка та догляд",
    bullets: [
      "Покрокове створення вінка",
      "Надійне кріплення рослин",
      "Акуратність та довговічність",
      "Розміщення в інтер'єрі",
      "Умови зберігання",
    ],
    imageMobile: "/images/masterclass-vinok/curriculum-3.webp",
    imageDesktop: "/images/masterclass-vinok/curriculum-3.webp",
