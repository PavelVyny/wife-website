const heroDecorElements = [
  { src: "/images/masterclass-vinok/hero/decor-5.webp", width: 200, height: 200, visibility: 'tablet-down' as const, style: "top: 16%; left: 4%; width: 53px; height: auto; --slide-x: -80px; --slide-y: -40px; animation-delay: 0.3s;" },
  { src: "/images/masterclass-vinok/hero/decor-2.webp", width: 200, height: 200, visibility: 'tablet-down' as const, style: "top: 37%; left: 85%; width: 49px; height: auto; --slide-x: 80px; --slide-y: -20px; animation-delay: 0.35s;" },
  { src: "/images/masterclass-vinok/hero/decor-3.webp", width: 200, height: 200, visibility: 'tablet-down' as const, style: "top: 55%; left: 12%; width: 59px; height: auto; --slide-x: -100px; --slide-y: 20px; animation-delay: 0.4s;" },
  { src: "/images/masterclass-vinok/hero/decor-4.webp", width: 200, height: 200, visibility: 'tablet-down' as const, style: "top: 65%; left: 88%; width: 31px; height: auto; --slide-x: 60px; --slide-y: 10px; animation-delay: 0.5s;" },
  { src: "/images/masterclass-vinok/hero/decor-6.webp", width: 200, height: 200, visibility: 'tablet-down' as const, style: "top: 53%; left: 64%; width: 159px; height: auto; --slide-x: 100px; --slide-y: 40px; animation-delay: 0.45s;" },
];

const audienceCards = [
  {
    image: "/images/masterclass-vinok/audience-beginners.webp",
    imageAlt: "Новачки та початківці",
    title: "Новачки та початківці",
    description: "Ідеально підійде тим, хто ніколи не працював зі стабілізованими рослинами. Ви отримаєте базові знання про матеріали, принципи побудови композиції, правила поєднання кольорів, підходящий алгоритм створення вінка",
  },
  {
    image: "/images/masterclass-vinok/audience-decor.webp",
    imageAlt: "Шанувальники декору",
    title: "Шанувальники декору",
    description: "Ідеальний формат для тих, хто любить стильні деталі в інтер'єрі. Вінок зі стабілізованих рослин не потребує поливу та догляду, але при цьому має вигляд живого, дорогого та прикрашає кожен простір",
  },
  {
    image: "/images/masterclass-vinok/audience-inspiration.webp",
    imageAlt: "Ті, хто шукає натхнення",
