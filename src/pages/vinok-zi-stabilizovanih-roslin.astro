  "Технологічна карта створення вінка",
  "Рекомендації з догляду за стабілізованими рослинами",
  "Приклади робіт для натхнення",
];

const learningItems = [
  "Створите власний стильний вінок зі стабілізованих рослин",
  "Навчитеся працювати з текстурами та кольорами",
  "Зрозумієте принципи гармонійної композиції",
  "Додасте унікальний природний акцент у свій простір",
  "Отримаєте нові творчі навички",
];

const curriculumLessons = [
  {
    title: "Підготовка та",
    titleRest: "теоретичний блок",
    bullets: [
      "Що таке стабілізовані рослини та як вони зберігаються",
      "Особливості моху, квітів та декоративних елементів",
      "Часті помилки новачків",
      "Як поєднувати текстури",
      "Основи кольорових поєднань",
