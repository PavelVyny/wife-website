  { label: "Плоский мох", left: "28%", top: "75%" },
  { label: "Бавовна", left: "77%", top: "22%" },
  { label: "Колоски", left: "58%", top: "72%" },
  { label: "Верба", left: "22%", top: "38%" },
  { label: "Гілля", left: "82%", top: "48%" },
];

