---

<MasterclassLayout
  title="Вінок зі стабілізованих рослин — Floralab Education"
  description="Покроковий онлайн майстер-клас зі створення декоративного вінка зі стабілізованих рослин. Без поливу та догляду."
  currentPath="/vinok-zi-stabilizovanih-roslin"
  purchaseUrl={PURCHASE_URL}
  purchaseLabel="Придбати навчання"
>

  <MasterclassHero
    heroId="vinok-hero"
    bgMobile="/images/masterclass-vinok/hero/hero-bg.webp"
    dariaImg="/images/masterclass-vinok/hero/daria-vinok.webp"
    dariaAlt="Дар'я з вінком зі стабілізованих рослин"
    dariaWidth={600}
    dariaHeight={673}
    badgeText="Онлайн майстер-клас"
    titleLine1="Вінок зі"
    titleLine2="стабілізованих рослин"
    subtitle="Навчіться створювати стильний<br class='md:hidden' /> декоративний вінок для інтер'єру —<br class='md:hidden' /> без складних технік та досвіду"
    ctaText="Дізнатися більше"
    ctaHref="#pricing"
    ctaPulse={true}
    decorElements={heroDecorElements}
    bleedElement={{ src: "/images/masterclass-vinok/hero/decor-1.webp", width: 200, height: 200, style: "bottom: -40px; left: 7%; width: 132px; height: auto; --slide-x: -60px; --slide-y: 80px; animation-delay: 0.55s;" }}
  />

  <TargetAudienceSection
    titleImage="/images/masterclass-vinok/for-who-title.webp"
    titleImageAlt="Для кого цей майстер-клас"
    subtitle="Цей майстер-клас для тих, хто хоче створити стильний природний декор своїми руками, додати затишку в інтер'єр і спробувати новий формат творчості без складнощів і спеціальної підготовки"
    cards={audienceCards}
    decorLeftImage="/images/masterclass/decor-herb-cluster.webp"
    decorRightImage="/images/masterclass/decor-right-plant.webp"
  />

  <EducationalBlock
    titleImage="/images/masterclass-vinok/what-is-title.webp"
    titleImageAlt="Що таке стабілізовані рослини?"
    headingHighlight="Стабілізовані рослини"
    headingRest="— це натуральні рослини, які пройшли спеціальну обробку та зберегли свою форму, текстуру і колір"
    productImage="/images/masterclass-vinok/stabilized-product.webp"
    productImageAlt="Вінок зі стабілізованих рослин з позначеними елементами"
    productImageWidth={900}
    productImageHeight={817}
    hotspots={educationalHotspots}
    benefits={educationalBenefits}
    quoteImage="/images/masterclass-vinok/what-is-quote.webp"
    quoteImageAlt="Стабілізовані рослини зберігають натуральність"
  />

  <WhatsIncludedSection
    titleImage="/images/masterclass-vinok/whats-included-title.webp"
    titleImageAlt="Що входить у майстер-клас"
    items={includedItems}
    productImg1="/images/masterclass-vinok/included-img-1.webp"
    productImg1Alt="Вінок зі стабілізованих рослин"
    productImg2="/images/masterclass-vinok/included-img-2.webp"
    productImg2Alt="Процес створення вінка"
  />

  <PricingCta
    price="450 грн"
    originalPrice="1500 грн"
    ctaText="Придбати зараз"
    purchaseUrl={PURCHASE_URL}
    course="wreath"
    productImg1="/images/masterclass-vinok/pricing-product-1.webp"
    productImg2="/images/masterclass-vinok/pricing-product-2.webp"
    bannerImg="/images/masterclass-vinok/pricing-banner.webp"
  />

  <LearningOutcomes
    titleImage="/images/masterclass-vinok/results-title.webp"
    items={learningItems}
    img1="/images/masterclass-vinok/results-interior-1.webp"
    img1Alt="Вінок зі стабілізованих рослин в інтер'єрі"
    img2="/images/masterclass-vinok/results-interior-2.webp"
    img2Alt="Вінок на дверях — декор для дому"
    decorImg="/images/masterclass-vinok/results-decor.webp"
    decorStyle="width: 118px; z-index: 5; left: 39px; bottom: -20px;"
  />

  <InstructorSection />

  <ValueProps cards={valueCards} />

  <CurriculumSection
    titleImage="/images/masterclass-vinok/curriculum-title.webp"
    titleImageAlt="Програма майстер-класу"
    lessons={curriculumLessons}
    layout="stacked"
    timelineClass="curriculum-timeline-k"
  />

  <FaqSection
    titleImage="/images/masterclass-vinok/faq-title.webp"
    faqs={faqs}
  />

</MasterclassLayout>

<style is:global>
  /* Curriculum vertical timeline line -- vinok-specific (stacked, 3 lessons with bullets) */
  .curriculum-timeline-k {
    --timeline-bottom: 320px;
  }
  .curriculum-timeline-k::before {
    content: '';
    position: absolute;
    left: 32px;
    top: 18px;
    bottom: var(--timeline-bottom);
    width: 1px;
    background: #d9d9d9;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .curriculum-timeline-k::before { left: 18px; }
  }
  @media (min-width: 1024px) {
    .curriculum-timeline-k::before { left: calc(40% + 48px + 18px); --timeline-bottom: 120px; }
  }
</style>
