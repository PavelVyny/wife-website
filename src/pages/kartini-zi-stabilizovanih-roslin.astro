---
import MasterclassLayout from '../layouts/MasterclassLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import InstructorSection from '../components/InstructorSection.astro';
import ValueProps from '../components/ValueProps.astro';
import PricingCta from '../components/PricingCta.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BotanicalElement from '../components/BotanicalElement.astro';
import { Image } from 'astro:assets';
import dariaPhoto from '../assets/about/daria-photo.webp';
import stabilizedArt from '../assets/masterclass/stabilized-art-product.webp';
import stabilizedArt2 from '../assets/masterclass/stabilized-art-product-2.webp';

const PURCHASE_URL = 'https://secure.wayforpay.com/payment/s9517959b27ff';

const valueCards = [
  {
    title: "Знання, які не знайти на YouTube",
    description: "Перевірені секрети та підходи, напрацьовані роками практики зі стабілізованими рослинами.",
    icon: "🎓",
  },
  {
    title: "Покроковий алгоритм",
    description: "Від вибору матеріалів та основи до створення та догляду за готовою картиною — повний супровід.",
    icon: "📋",
  },
  {
    title: "Економія часу та грошей",
    description: "Вся потрібна інформація зібрана та структурована — без зайвих пошуків та помилок.",
    icon: "⏱️",
  },
];

const galleryImages = [
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/Generated-Image-November-05-2025-4_06PMwf-e1773164461674.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 1',
  },
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/%D0%A1%D0%BB%D0%BE%D1%8B%D0%B2%D0%B9-3.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 2',
  },
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/%D0%A1%D0%BB%D1%86%D0%B2%D1%86%D0%B2%D0%BE%D0%B9-4.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 3',
  },
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/%D0%A1%D1%8B%D0%B2%D1%8B%D0%B2%D0%BB%D0%BE%D0%B9-5.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 4',
  },
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/%D0%A1%D0%BB%D1%8B%D0%B2%D1%8B%D0%BE%D0%B9-6.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 5',
  },
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/%D0%A1%D0%BB%D0%BE%D1%81%D0%B4%D1%81-26-1.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 6',
  },
  {
    url: 'https://floralabeducation.com.ua/wp-content/uploads/2026/03/%D0%A1%D0%BB%D0%BE%D1%8B%D0%B2%D1%8B%D0%B2-3.png',
    alt: 'Картина зі стабілізованих рослин — приклад роботи 7',
  },
];

const faqs = [
  {
    q: 'Чи можуть навчатися новачки без досвіду?',
    a: ['Так, курс розрахований на новачків. Перший урок розбирає теорію простою мовою, без складних термінів. Вам не потрібна художня освіта чи попередній досвід.'],
  },
  {
    q: 'Скільки часу потрібно на створення панно?',
    a: [
      'Тривалість уроків — 30–60 хвилин кожен. Практичне створення панно займає приблизно 2–4 години.',
      'Усі уроки у записі, тому ви можете працювати у зручному для вас темпі.',
    ],
  },
  {
    q: 'Скільки коштує закупка матеріалів?',
    a: [
      'Орієнтовна вартість матеріалів — 1500–2000 грн, залежно від розміру панно, обраної основи, рослин та декору.',
      'Частина матеріалів залишиться для наступних робіт.',
    ],
  },
  {
    q: 'Чи потрібно мати спеціальні інструменти?',
    a: ['Ні, потрібні лише доступні інструменти, які легко знайти. У курсі надається повний список із посиланнями, де все придбати.'],
  },
  {
    q: 'Чи є обмеження за часом доступу до відеоуроків?',
    a: ['Ні, доступ до відео не обмежений. Ви можете повертатися до матеріалів у будь-який час.'],
  },
  {
    q: 'Що робити, якщо у мене виникнуть питання під час навчання?',
    a: ['Ви завжди можете написати Даші через Instagram — вона із задоволенням допоможе та відповість на будь-які запитання.'],
  },
  {
    q: 'Чи можна подарувати цей майстер-клас?',
    a: ['Так, це чудовий подарунок для творчих людей! Просто повідомте, і ми оформимо доступ для вашого друга чи близького.'],
  },
  {
    q: 'Де проходить навчання?',
    a: [
      'Навчання проходить повністю онлайн. Відеоуроки у записі доступні через Telegram-канал.',
      'Ви можете дивитися уроки в будь-який час і з будь-якого пристрою.',
    ],
  },
  {
    q: 'Як можна оплатити майстер-клас?',
    a: ['Оплату можна здійснити через банківський переказ на ФОП-рахунок.'],
  },
  {
    q: 'Що я отримаю після проходження майстер-класу?',
    a: [
      'Ви створите власну стильну картину зі стабілізованих рослин.',
      'Дізнаєтеся, як обирати та підготовлювати матеріали.',
      'Отримаєте покрокові інструкції від початку до фінального оформлення.',
      'Навчитеся правильно зберігати та доглядати за стабілізованими виробами.',
    ],
  },
];
---

<MasterclassLayout
  title="Картини зі стабілізованих рослин — Floralab Education"
  description="Покроковий онлайн майстер-клас зі створення дизайнерської картини зі стабілізованого моху та рослин. Без поливу та догляду."
  currentPath="/kartini-zi-stabilizovanih-roslin"
  purchaseUrl={PURCHASE_URL}
  purchaseLabel="Придбати навчання"
>

  {/* ===== HERO ===== */}
  <section class="relative bg-brand-cream/30 pt-[96px] pb-[40px] md:pt-[120px] md:pb-[56px] lg:pt-[140px] lg:pb-[72px] overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-[24px] md:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-[48px] lg:items-center">
        <div class="mb-[32px] lg:mb-0 relative z-10">
          <p class="font-heading text-[#7cab06] text-[14px] tracking-[2px] uppercase mb-[12px]">
            Онлайн майстер-клас
          </p>
          <h1 class="font-heading text-brand-dark text-[32px] md:text-[42px] lg:text-[56px] leading-[1.15] mb-[20px]">
            Картини зі стабілізованих рослин
          </h1>
          <p class="text-brand-dark/70 text-[16px] md:text-[18px] leading-[28px] mb-[28px] max-w-[540px]">
            Створіть власну унікальну картину без художньої освіти та досвіду
          </p>
          <a
            href={PURCHASE_URL}
            class="inline-flex items-center justify-center px-[32px] py-[14px] bg-[#E63380] text-white rounded-full font-heading text-[18px] hover:scale-[1.02] transition-transform"
            style="box-shadow: 0 10px 30px rgba(230,51,128,0.35);"
          >
            Придбати зараз
          </a>
        </div>
        <div class="relative flex items-center justify-center">
          <Image
            src={dariaPhoto}
            alt="Даша з картиною зі стабілізованих рослин"
            class="w-full max-w-[420px] mx-auto rounded-[28px] relative z-10"
            loading="eager"
          />
          <BotanicalElement src="/images/masterclass/decor-moss-1.webp" top="10%" right="-10%" size="w-20 h-20 md:w-28 md:h-28" animationType="slide-in" slideX="60px" slideY="-30px" delay="0.3s" />
          <BotanicalElement src="/images/masterclass/decor-branch-1.webp" bottom="15%" left="-5%" size="w-16 h-16 md:w-24 md:h-24" animationType="slide-in" slideX="-50px" slideY="20px" delay="0.5s" />
          <BotanicalElement src="/images/masterclass/decor-flower-2.webp" top="-5%" left="10%" size="w-20 h-20 md:w-28 md:h-28" animationType="float" delay="0.2s" opacity="opacity-70" />
        </div>
      </div>
    </div>
    <BotanicalElement src="/images/masterclass/decor-fern-1.webp" bottom="5%" left="2%" size="w-16 h-16 md:w-24 md:h-24" animationType="float" delay="1s" opacity="opacity-40" className="hidden md:block" />
  </section>

  {/* ===== TARGET AUDIENCE ===== */}
  <section class="relative bg-white px-[24px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    {/* Decorative elements */}
    <img src="/images/masterclass/decor-herb-cluster.webp" alt="" width="280" height="268"
      class="hidden lg:block absolute pointer-events-none z-0 decor-sway"
      style="top: 5%; left: -3%; width: 210px; height: auto; opacity: 0.9; filter: blur(1px); --dur: 7s; --del: -2s;" />
    <img src="/images/masterclass/decor-right-plant.webp" alt="" width="929" height="906"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 2%; right: 1%; width: 160px; height: auto; --dur: 6s; --del: -1s;" />

    <div class="max-w-[1280px] mx-auto relative z-10">
      <div class="flex justify-center mb-[8px] reveal">
        <SectionHeader mainTitle="Для кого" accentTitle="Цей майстер-клас" />
      </div>
      <p class="text-brand-dark/70 text-[16px] md:text-[18px] leading-[28px] text-center mb-[40px] max-w-[780px] mx-auto reveal">
        Цей майстер-клас для тих, хто хоче створити стильний природний декор своїми руками, додати затишку в інтер'єр і спробувати новий формат творчості без складнощів і спеціальної підготовки
      </p>

      {/* 2×2 grid — image left, text right */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px] md:gap-[20px]">

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-beginners.webp" alt="Новачки та початківці"
            width="800" height="783"
            class="flex-shrink-0 w-[140px] h-[140px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Новачки та початківці</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Ідеально підійде для тих, хто ніколи не працював із стабілізованими рослинами. Ви отримаєте більше знань про матеріали, принципи побудови композиції, правила поєднання кольорів, підходящий алгоритм створення картини</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-decor.webp" alt="Шанувальники декору"
            width="800" height="783"
            class="flex-shrink-0 w-[140px] h-[140px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Шанувальники декору</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Ідеальний формат для тих, хто обожнює стильні деталі в інтер'єрі. Картина зі стабілізованих рослин не потребує поливу та догляду, але при цьому має вигляд живого, дорогого та прикрашає кожен простір</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-inspiration.webp" alt="Ті, хто шукає натхнення"
            width="800" height="783"
            class="flex-shrink-0 w-[140px] h-[140px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Ті, хто шукає натхнення</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Майстер-клас стане простором для творчого перезавантаження. Робота з природними текстурами знижує стрес, допомагає відволіктись та дає задоволення від створеного результату</p>
          </div>
        </div>

        <div class="bg-white border border-[#E0E0E0] rounded-[20px] p-[20px] flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-[16px] md:gap-[20px] reveal">
          <img src="/images/masterclass/audience-gifts.webp" alt="Любителі подарунків"
            width="800" height="783"
            class="flex-shrink-0 w-[140px] h-[140px] md:w-[160px] md:h-[160px] object-contain"
            loading="lazy" />
          <div>
            <h3 class="font-heading text-[#1a1a1a] text-[20px] md:text-[22px] leading-[1.3] mb-[8px]">Любителі подарунків</h3>
            <p class="text-[#8a8a8a] text-[15px] leading-[24px] text-left">Картина, створена власноруч — це особливий подарунок. Ви можете зробити панно для близьких, створити декор на замовлення або подарувати собі на свято новий творчий досвід</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ===== WHAT ARE STABILIZED PLANTS ===== */}
  <section class="relative bg-brand-cream/20 px-[24px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    {/* Decorative botanical elements — mirroring florarium description section */}
    <img src="/images/masterclass/decor-leaf-3.webp" alt="" width="180" height="200"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 12%; left: -1.5%; width: 130px; height: auto; opacity: 0.8; --dur: 7s; --del: -3s;" />
    <img src="/images/masterclass/decor-fern-2.webp" alt="" width="200" height="220"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim-mirror"
      style="bottom: 8%; right: -1%; width: 140px; height: auto; opacity: 0.75; --dur: 8s; --del: -1.5s;" />

    <div class="max-w-[1280px] mx-auto relative z-10">
      <div class="flex justify-center mb-[12px] reveal">
        <SectionHeader mainTitle="Що таке" accentTitle="Стабілізовані рослини?" />
      </div>

      <p class="text-center text-brand-dark/80 text-[16px] md:text-[18px] leading-[30px] mb-[36px] max-w-[720px] mx-auto reveal">
        <strong>Стабілізовані рослини</strong> — це натуральні рослини, які пройшли спеціальну обробку та зберегли свою форму, текстуру і колір
      </p>

      {/* Centered illustration with floating animation */}
      <div class="flex justify-center mb-[40px] reveal">
        <div class="stabilized-bob">
          <Image
            src={stabilizedArt2}
            alt="Картина зі стабілізованих рослин — ілюстрація"
            class="w-full max-w-[380px] md:max-w-[480px] lg:max-w-[560px] mx-auto rounded-[24px]"
            loading="lazy"
          />
        </div>
      </div>

      {/* 3 key benefit items — horizontal row */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[24px] max-w-[900px] mx-auto">
        {[
          "Не потребують поливу та догляду",
          "Не в'януть та зберігають вигляд роками",
          "Поєднують натуральність та практичність",
        ].map((item) => (
          <div class="flex flex-col items-center text-center gap-[12px] reveal">
            <div class="w-[52px] h-[52px] rounded-full bg-[#7cab06] flex items-center justify-center flex-shrink-0">
              <svg width="22" height="22" viewBox="0 0 12 12" fill="none">
                <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="font-heading text-brand-dark text-[17px] leading-[26px]">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== WHAT'S INCLUDED ===== */}
  <section class="bg-white px-[24px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    <div class="max-w-[1280px] mx-auto">
      <div class="flex justify-center mb-[12px] reveal">
        <SectionHeader mainTitle="Що входить" accentTitle="У майстер-клас" />
      </div>
      <div class="lg:grid lg:grid-cols-2 lg:gap-[48px] lg:items-center mt-[32px]">
        <div class="reveal">
          <ul class="space-y-[14px]">
            {[
              "Три покрокові відео-уроки",
              "Повний список матеріалів із зазначенням, де їх купити (з посиланнями на магазини)",
              "Рекомендації щодо вибору рослин та інструментів",
              "Технологічна карта круглого панно",
              "Рекомендації з догляду за стабілізованими рослинами",
              "Приклади робіт для натхнення",
            ].map((item) => (
              <li class="text-brand-dark/80 text-[16px] leading-[26px] flex gap-[10px] items-start">
                <span class="flex-shrink-0 w-[22px] h-[22px] rounded-full bg-[#7cab06] flex items-center justify-center mt-[3px]">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="mt-[24px] lg:mt-0 reveal">
          <Image
            src={stabilizedArt}
            alt="Що входить у майстер-клас з картин"
            class="w-full max-w-[400px] mx-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ===== CURRICULUM ===== */}
  <section class="relative bg-brand-cream/20 px-[24px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px] overflow-hidden">
    <img src="/images/masterclass/decor-fern-1.webp" alt="" width="190" height="210"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="top: 8%; left: -1.5%; width: 145px; height: auto; opacity: 0.75; --dur: 8s; --del: -1s;" />
    <img src="/images/masterclass/decor-wreath-1.webp" alt="" width="200" height="200"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style="bottom: 6%; right: -0.5%; width: 130px; height: auto; opacity: 0.7; --dur: 6s; --del: -3s;" />

    <div class="max-w-[1280px] mx-auto relative z-10">
      <div class="flex justify-center mb-[32px] md:mb-[48px] reveal">
        <SectionHeader mainTitle="Програма" accentTitle="Майстер-класу" />
      </div>

      {/* Lesson 1 — image left, text right */}
      <div class="lg:grid lg:grid-cols-2 lg:gap-[48px] lg:items-center mb-[48px] md:mb-[64px] reveal">
        <div class="mb-[24px] lg:mb-0 overflow-hidden rounded-[16px]">
          <img
            src="/images/masterclass/paintings-lesson-1.webp"
            alt="Підготовка та теоретичний блок"
            width="600" height="500"
            class="w-full max-w-[500px] mx-auto object-cover curriculum-img"
            loading="lazy"
          />
        </div>
