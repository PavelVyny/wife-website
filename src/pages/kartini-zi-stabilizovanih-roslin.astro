const heroDecorElements = [
  { src: "/images/masterclass/hero/decor-cookie-1.webp", width: 213, height: 215, visibility: "mobile-only" as const, style: "top: 10%; left: 2%; width: 42px; height: auto; --slide-x: -80px; --slide-y: -40px; animation-delay: 0.3s;" },
  { src: "/images/masterclass/hero/decor-cookie-3.webp", width: 200, height: 185, visibility: "tablet-down" as const, style: "top: 64%; right: 2%; width: 42px; height: auto; --slide-x: 80px; --slide-y: 20px; animation-delay: 0.6s;" },
  { src: "/images/masterclass/hero/decor-plant-pot.webp", width: 280, height: 310, visibility: "mobile-only" as const, style: "top: 60%; left: 4%; width: 56px; height: auto; --slide-x: -60px; --slide-y: 80px; animation-delay: 0.4s;" },
  { src: "/images/masterclass/hero/decor-small-plant.webp", width: 200, height: 250, visibility: "tablet-down" as const, style: "top: 10%; right: 0%; width: 50px; height: auto; --slide-x: 100px; --slide-y: -60px; animation-delay: 0.35s;" },
  { src: "/images/masterclass/hero/decor-succulent.webp", width: 213, height: 215, visibility: "desktop-only" as const, style: "top: 56%; right: 0%; width: 55px; height: auto; --slide-x: 100px; --slide-y: 20px; animation-delay: 0.3s;" },
  { src: "/images/masterclass/hero/decor-green-3.webp", width: 162, height: 202, visibility: "desktop-only" as const, style: "top: 14%; right: 0%; width: 80px; height: auto; --slide-x: 100px; --slide-y: -40px; animation-delay: 0.3s;" },
];

const audienceCards = [
  {
    image: "/images/masterclass-kartini/audience-beginners.webp",
    imageAlt: "Новачки та початківці",
    title: "Новачки та початківці",
    description: "Ідеально підійде тим, хто ніколи не працював зі стабілізованими рослинами. Ви отримаєте базові знання про матеріали, принципи побудови композиції, правила поєднання кольорів, підходящий алгоритм створення картини",
  },
  {
    image: "/images/masterclass-kartini/audience-decor.webp",
    imageAlt: "Шанувальники декору",
    title: "Шанувальники декору",
    description: "Ідеальний формат для тих, хто любить стильні деталі в інтер'єрі. Картина зі стабілізованих рослин не потребує поливу та догляду, але при цьому має вигляд живого, дорогого та прикрашає кожен простір",
  },
  {
    image: "/images/masterclass-kartini/audience-inspiration.webp",
    imageAlt: "Ті, хто шукає натхнення",
    title: "Ті, хто шукає натхнення",
    description: "Майстер-клас стане простором для творчого перезавантаження. Робота з природними текстурами чудово знімає стрес, допомагає відволіктись та дає задоволення від створеного результату",
  },
  {
    image: "/images/masterclass-kartini/audience-gifts.webp",
    imageAlt: "Любителі подарунків",
    title: "Любителі подарунків",
    description: "Картина, створена власноруч, — це особливий подарунок. Ви зможете зробити унікальну річ для близьких, створити декор на замовлення або подарувати собі новий творчий досвід",
  },
];

const educationalHotspots = [
  { label: "Дерев'яна основа", left: "83.5%", top: "20.8%" },
  { label: "Ягель зелений", left: "33.5%", top: "22.8%" },
  { label: "Коряга", left: "69.5%", top: "45.8%" },
  { label: "Амарант", left: "23.5%", top: "55.8%" },
  { label: "Плоский мох", left: "60.5%", top: "77.8%" },
];

const educationalBenefits = [
  "Не потребують догляду",
  "Не в'януть",
  "Не потребують світла",
  "Зберігають вигляд роками",
  "Поєднують натуральність та практичність",
];

const includedItems = [
  "Три покрокові відео-уроки",
  "Повний список матеріалів із зазначенням, де їх купити (з посиланнями на магазини)",
  "Рекомендації щодо вибору рослин та інструментів",
  "Технологічна карта круглого панно",
  "Рекомендації з догляду за стабілізованими рослинами",
  "Приклади робіт для натхнення",
];

const learningItems = [
  "Створите стильне панно зі стабілізованих рослин власноруч",
  "Зрозумієте основи композиції та роботи з природними текстурами",
  "Зможете повторити або адаптувати техніку для інших форматів",
  "Отримаєте структуровану систему знань замість хаотичних спроб",
  "Додасте в інтер'єр декор, який не потребує догляду",
];

const curriculumLessons = [
  {
    title: "Підготовка та",
    titleRest: "теоретичний блок",
    description: "Що таке стабілізовані рослини, особливості моху та декоративних елементів, часті помилки новачків, основи кольорових поєднань та візуальні акценти",
    imageMobile: "/images/masterclass-kartini/curriculum-1.webp",
    imageDesktop: "/images/masterclass-kartini/curriculum-1.webp",
    imageAlt: "Підготовка та теоретичний блок",
  },
  {
    title: "Огляд матеріалів",
    titleRest: "та побудова композиції",
    description: "Інструменти для роботи, основа для панно, різновиди стабілізованих рослин та сухоцвітів, підготовка елементів до монтажу",
    imageMobile: "/images/masterclass-kartini/curriculum-2.webp",
    imageDesktop: "/images/masterclass-kartini/curriculum-2.webp",
    imageAlt: "Огляд матеріалів та побудова композиції",
  },
  {
    title: "Створення",
    titleRest: "круглого панно",
    description: "Покрокове створення, як зробити роботу акуратною та довговічною, догляд за стабілізованими рослинами та умови зберігання",
    imageMobile: "/images/masterclass-kartini/curriculum-3.webp",
    imageDesktop: "/images/masterclass-kartini/curriculum-3.webp",
    imageAlt: "Створення панно",
