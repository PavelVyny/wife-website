---

<MasterclassLayout
  title="Картини зі стабілізованих рослин — Floralab Education"
  description="Покроковий онлайн майстер-клас зі створення дизайнерської картини зі стабілізованого моху та рослин. Без поливу та догляду."
  currentPath="/kartini-zi-stabilizovanih-roslin"
  purchaseUrl={PURCHASE_URL}
  purchaseLabel="Придбати навчання"
>

  <MasterclassHero
    heroId="kartini-hero"
    bgMobile="/images/masterclass-kartini/hero/hero-bg.webp"
    dariaImg="/images/masterclass-kartini/hero/daria-kartini.webp"
    dariaAlt="Дар'я з картиною зі стабілізованих рослин"
    dariaWidth={600}
    dariaHeight={673}
    badgeText="Онлайн майстер-клас"
    titleLine1="Картини зі"
    titleLine2="стабілізованих рослин"
    underlineWord="Картини"
    subtitle="Створіть власну унікальну<br class='md:hidden' /> картину без художньої освіти та<br class='md:hidden' /> досвіду"
    ctaText="Дізнатися більше"
    ctaHref="#pricing"
    ctaPulse={true}
    decorElements={heroDecorElements}
    bleedElement={{ src: "/images/masterclass-kartini/hero/decor-1.webp", width: 200, height: 200, style: "bottom: -40px; left: 2%; height: auto; filter: brightness(100%) contrast(100%) saturate(75%) blur(5.3px) hue-rotate(0deg); --slide-x: -60px; --slide-y: 100px; animation-delay: 0.15s; width: 88px;" }}
  />

  <TargetAudienceSection
    titleImage="/images/masterclass/for-who-title.webp"
    titleImageAlt="Для кого цей майстер-клас"
    subtitle="Цей майстер-клас для тих, хто хоче створити стильний природний декор своїми руками, додати затишку в інтер'єр і спробувати новий формат творчості без складнощів і спеціальної підготовки"
    cards={audienceCards}
  />

  <EducationalBlock
    titleImage="/images/masterclass-kartini/what-is-title.webp"
    titleImageAlt="Що таке стабілізовані рослини?"
    headingHighlight="Стабілізовані рослини"
    headingRest="— це натуральні рослини, які пройшли спеціальну обробку та зберегли свою форму, текстуру і колір"
    productImage="/images/masterclass-kartini/stabilized-product.webp"
    productImageAlt="Картина зі стабілізованих рослин з позначеними елементами"
    productImageWidth={900}
    productImageHeight={817}
    hotspots={educationalHotspots}
    benefits={educationalBenefits}
    quoteImage="/images/masterclass-kartini/what-is-quote.webp"
    quoteImageAlt="Стабілізовані рослини зберігають натуральність"
  />

  <WhatsIncludedSection
    titleImage="/images/masterclass/whats-included-title.webp"
    titleImageAlt="Що входить у майстер-клас"
    items={includedItems}
    productImg1="/images/masterclass-kartini/included-img-1.webp"
    productImg1Alt="Картина зі стабілізованих рослин"
    productImg2="/images/masterclass-kartini/included-img-2.webp"
    productImg2Alt="Процес створення картини"
  />

  <PricingCta
    price="450 грн"
    originalPrice="1500 грн"
    ctaText="Придбати зараз"
    purchaseUrl={PURCHASE_URL}
    course="paintings"
    productImg1="/images/masterclass-kartini/pricing-product-1.webp"
    productImg2="/images/masterclass-kartini/pricing-product-2.webp"
    bannerImg="/images/masterclass-kartini/pricing-banner.webp"
  />

  <LearningOutcomes
    titleImage="/images/masterclass-kartini/results-title.webp"
    items={learningItems}
    img1="/images/masterclass-kartini/results-img-1.webp"
    img1Alt="Результати — картина"
    img2="/images/masterclass-kartini/results-img-2.webp"
    img2Alt="Результати — процес"
    decorImg="/images/masterclass-kartini/results-decor.webp"
    decorStyle="width: 118px; z-index: 5; left: 39px; bottom: -20px;"
  />

  <InstructorSection />

  <ValueProps cards={valueCards} />

  <CurriculumSection
    titleImage="/images/masterclass/curriculum-title.webp"
    titleImageAlt="Програма майстер-класу"
    lessons={curriculumLessons}
    layout="zigzag"
    timelineClass="curriculum-timeline"
  />

  <CtaButton />

  <FaqSection
    titleImage="/images/masterclass/faq-title.webp"
    faqs={faqs}
  />

</MasterclassLayout>

