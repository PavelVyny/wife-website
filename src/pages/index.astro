---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import MasterclassCard from '../components/MasterclassCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Floralab Education — Онлайн-навчання флористиці">
	<Navigation />
	<main>
		<Hero 
			title="КРЕАТИВНІ МАЙСТЕР-КЛАСИ ВІД FLORALAB"
			subtitle="Практичні онлайн майстер-класи для кожного, хто хоче зануритися у світ природи та ручної роботи"
			ctaText="Доступні навчання"
			ctaLink="#courses"
			imageAlt="Daria from Floralab"
		/>
		
		<section id="courses" class="py-24 bg-white overflow-hidden">
			<div class="container mx-auto px-4 flex flex-col items-center">
				<SectionHeader mainTitle="ДОСТУПНІ" accentTitle="МАЙСТЕР-КЛАСИ" />
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto mt-8">
					<MasterclassCard 
						title="Створення флораріуму в скляній вазі"
						subtitle="Станьте частиною чарівного світу природи"
						link="/stvorennya-florariumu"
					/>
					<MasterclassCard 
						title="Створення картини зі стабілізованих рослин"
						subtitle="Створіть свій вічнозелений шедевр"
						link="/kartini-zi-stabilizovanih-roslin"
						isNew={true}
					/>
				</div>
			</div>
		</section>

		<section id="about" class="py-24 bg-brand-cream/20">
			<div class="container mx-auto px-4 flex flex-col items-center text-center">
				<SectionHeader mainTitle="ІНФОРМАЦІЯ" accentTitle="ПРО МЕНЕ" />
				<div class="max-w-xl mx-auto mt-8 text-lg text-brand-dark/80 leading-relaxed font-sans">
					<p class="font-heading text-2xl text-brand-dark mb-6">Привіт! Мене звати Даша.</p>
					<p class="mb-6">Я — майстер-флорист, ботанік і викладач, засновниця майстерні декору <span class="text-brand-dark font-bold">Floralab</span>.</p>
					<p class="text-base text-brand-dark/60 italic px-8 border-l-2 border-brand-lime">
						Понад 5 років я створюю дивовижні речі з рослин і ділюся цим досвідом з тисячами учнів по всьому світу.
					</p>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
