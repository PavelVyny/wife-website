---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import MasterclassCard from '../components/MasterclassCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BotanicalElement from '../components/BotanicalElement.astro';
import Footer from '../components/Footer.astro';
import StatsSection from '../components/StatsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import FaqSection from '../components/FaqSection.astro';
---

<Layout title="Floralab Education — Онлайн-навчання флористиці">
	<Navigation currentPath="/" />
	<main>
		<Hero
			title="КРЕАТИВНІ МАЙСТЕР-КЛАСИ ВІД FLORALAB"
			subtitle="Практичні онлайн майстер-класи для кожного, хто хоче зануритися у світ природи та ручної роботи"
			ctaText="Доступні навчання"
			ctaLink="#courses"
			imageAlt="Daria from Floralab"
		/>

		{/* ===== SECTION HEADER BANNER ===== */}
		<section class="bg-white px-[9.75px] pt-[6px] pb-[20px] md:px-8 max-w-[1280px] mx-auto reveal">
			<img
				src="/images/masterclass/section-header-banner.webp"
				alt="Доступні Майстер-Класи"
				class="w-full h-auto md:max-w-[672px] md:mx-auto"
				loading="lazy"
			/>
		</section>

		{/* ===== COURSES / MASTERCLASSES SECTION ===== */}
		<section id="courses" class="relative bg-white pb-[20px] md:pb-[30px] lg:pb-[40px]">
			<div class="relative z-10 px-[9.75px] md:px-8 max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[20px] md:gap-[30px]">

				{/* Card 1: Florarium — no badge */}
				<div class="relative w-full">
					<MasterclassCard
						title="Створення флораріуму<br/>в скляній вазі"
						link="/stvorennya-florariumu"
						image="/images/masterclass/florarium-product.webp"
						imageAlt="Флораріум у скляній вазі з мохом та мініатюрними деревами"
						bgImage="/images/masterclass/bg/florarium-bg.webp"
						className="min-h-[515px] md:min-h-0"
					>
						{/* Decorative elements for card 1 */}
						<img src="/images/masterclass/decor-small-leaf.webp" alt="" class="decor-fade absolute left-[31px] bottom-[145px] w-[34px] h-[32px] z-20 pointer-events-none" loading="lazy" />
						<img src="/images/masterclass/decor-leaf-2.webp" alt="" class="decor-fade absolute right-[12.5px] bottom-[121px] w-[29px] h-[29px] z-20 pointer-events-none" style="transition-delay: 0.2s;" loading="lazy" />
						<img src="/images/masterclass/decor-pot-2.webp" alt="" class="decor-fade absolute right-[54.5px] bottom-[18px] w-[120px] h-[137px] z-20 pointer-events-none" style="transition-delay: 0.3s;" loading="lazy" />
						<img src="/images/masterclass/decor-moss-blur.webp" alt="" class="decor-fade absolute right-[43.5px] bottom-[219px] w-[86px] h-[89px] z-20 pointer-events-none" style="filter: blur(3.95px); transition-delay: 0.15s;" loading="lazy" />
					</MasterclassCard>
				</div>

				{/* Card 2: Stabilized plants picture — НОВИНКА */}
				<div class="relative w-full">
					<MasterclassCard
						title="Створення картини<br/>зі стаблізованих рослин"
						link="/kartini-zi-stabilizovanih-roslin"
						image="/images/masterclass/stabilized-art-product-2.webp"
						imageAlt="Картина зі стабілізованих рослин на дерев'яній основі"
						bgImage="/images/masterclass/bg/stabilized-art-bg.webp"
						isNew={true}
						rotateImage={true}
						className="min-h-[525px] md:min-h-0"
					>
						{/* Decorative elements for card 2 */}
						<img src="/images/masterclass/decor-fern-2.webp" alt="" class="decor-fade absolute right-[2.5px] bottom-[289px] w-[77px] h-[65px] z-20 pointer-events-none" loading="lazy" />
						<img src="/images/masterclass/decor-small-moss.webp" alt="" class="decor-fade absolute left-[23px] bottom-[160px] w-[35px] h-[34px] z-20 pointer-events-none" style="transition-delay: 0.2s;" loading="lazy" />
						<img src="/images/masterclass/decor-moss-ball.webp" alt="" class="decor-fade absolute right-[0px] bottom-[40px] w-[122px] h-[110px] z-20 pointer-events-none" style="filter: blur(8px); transition-delay: 0.3s;" loading="lazy" />
					</MasterclassCard>
				</div>

				{/* Card 3: Wreath — СКОРО (coming soon, grayed out) */}
				<div class="relative w-full">
					<MasterclassCard
						title="Створення вінку<br/>зі стаблізованих рослин"
						link="/stvorennya-vinku"
						image="/images/masterclass/wreath-product-2.webp"
						imageAlt="Вінок зі стабілізованих рослин"
						bgImage="/images/masterclass/bg/wreath-bg.webp"
						isComingSoon={true}
						rotateImage={true}
						imageWidth="270px"
						className="min-h-[571px] md:min-h-0"
					>
						{/* Decorative elements for card 3 */}
						<img src="/images/masterclass/decor-leaf-3.webp" alt="" class="decor-fade absolute left-[70%] bottom-[333px] w-[62px] h-[62px] z-20 pointer-events-none" loading="lazy" />
						<img src="/images/masterclass/decor-branch-1.webp" alt="" class="decor-fade absolute right-[40%] bottom-[61px] w-[122px] h-[122px] z-20 pointer-events-none" style="transition-delay: 0.2s;" loading="lazy" />
					</MasterclassCard>
				</div>

			</div>
		</section>

		<AboutSection />

		<StatsSection />

		<FaqSection />
	</main>
	<Footer />
</Layout>
