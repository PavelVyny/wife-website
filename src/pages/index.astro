---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import MasterclassCard from '../components/MasterclassCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BotanicalElement from '../components/BotanicalElement.astro';
import Footer from '../components/Footer.astro';
import StatsSection from '../components/StatsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { Image } from 'astro:assets';
import sectionHeaderBanner from '../assets/masterclass/section-header-banner.webp';
import faqBanner from '../assets/faq/header-banner.webp';

const mainPageFaqs = [
  {
    q: 'Що я отримаю після проходження майстер-класу?',
    a: [
      'Ви створите свій унікальний флораріум, який прикрасить ваш дім або стане чудовим подарунком для близьких.',
      'Дізнаєтеся, як правильно вибрати та закупити матеріали.',
      'Отримаєте покрокові інструкції зі створення флораріуму.',
      'Навчитеся доглядати за флораріумом, щоб він залишався гарним тривалий час.',
      'Усі відео залишаються у вас у доступі, щоб ви могли працювати у своєму темпі.',
    ],
  },
  {
    q: 'Де проходить навчання?',
    a: [
      'Навчання проходить повністю онлайн: 4 відеоуроки у записі будуть розміщені на YouTube.',
      'Ви отримаєте доступ до всіх матеріалів через Telegram-канал, що дуже зручно!',
      'Ви можете дивитися уроки в будь-який час і з будь-якого пристрою.',
    ],
  },
  {
    q: 'Як можна оплатити майстер-клас?',
    a: ['Оплату можна здійснити через банківський переказ на ФОП-рахунок.'],
  },
  {
    q: 'Чи можу я навчатися, якщо ніколи не працював із рослинами?',
    a: ['Так, майстер-клас розрахований навіть на початківців. Я все детально пояснюю у відео, тому вам не знадобляться попередні знання.'],
  },
  {
    q: 'Скільки часу потрібно на створення флораріуму?',
    a: [
      'Ви можете працювати у своєму темпі. Для кожного уроку потрібно приблизно 30–60 хвилин, плюс час для закупівлі матеріалів.',
      'Усі уроки доступні в записі, тому ви можете розподілити час так, як вам зручно.',
    ],
  },
  {
    q: 'Скільки коштує закупка матеріалів?',
    a: [
      'Вартість залежить від того, які матеріали ви оберете: який декор та елементи захочете додати, яку скляну вазу або форму виберете для флораріуму.',
      'У середньому закупівля матеріалів для одного флораріуму обійдеться приблизно у 700–1000 грн.',
      'При цьому частина матеріалів, як-от декор, залишиться, і ви зможете використовувати їх для наступних робіт.',
    ],
  },
  {
    q: 'Чи потрібно мати спеціальні інструменти або матеріали?',
    a: ['Усе необхідне легко знайти в магазинах або замовити онлайн. У першому уроці я розповім, що саме вам знадобиться і де це можна придбати.'],
  },
  {
    q: 'Чи є обмеження за часом доступу до відеоуроків?',
    a: ['Ні, доступ до відео не обмежений. Ви можете повертатися до матеріалів у будь-який час.'],
  },
  {
    q: 'Що робити, якщо у мене виникнуть питання під час навчання?',
    a: ['Якщо у вас з\'являться питання, ви завжди можете написати мені через Instagram, і я із задоволенням допоможу.'],
  },
  {
    q: 'Чи можна подарувати цей майстер-клас іншій людині?',
    a: ['Так, звісно! Це чудовий подарунок для тих, хто любить творчість. Просто повідомте мене, і я оформлю доступ для вашого друга чи близького.'],
  },
];
---

<Layout title="Floralab Education — Онлайн-навчання флористиці">
	<Navigation currentPath="/" />
	<main id="main-content">
		<Hero
			title="КРЕАТИВНІ МАЙСТЕР-КЛАСИ ВІД FLORALAB"
			subtitle="Практичні онлайн майстер-класи для кожного, хто хоче зануритися у світ природи та ручної роботи"
			ctaText="Доступні навчання"
			ctaLink="#available-courses"
			imageAlt="Daria from Floralab"
		/>

		{/* ===== SECTION HEADER BANNER ===== */}
		<section id="available-courses" class="bg-white px-[9.75px] pt-[6px] pb-[20px] md:px-8 max-w-[1280px] mx-auto reveal scroll-mt-[100px]">
			<Image
				src={sectionHeaderBanner}
				alt="Доступні Майстер-Класи"
				class="w-full h-auto md:max-w-[538px] lg:max-w-[672px] md:mx-auto"
				loading="lazy"
			/>
		</section>

		{/* ===== COURSES / MASTERCLASSES SECTION ===== */}
		<section id="courses" class="relative bg-white pb-[20px] md:pb-[30px] lg:pb-[40px] scroll-mt-[100px]">
			<div class="relative z-10 px-[9.75px] md:px-8 max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[20px] md:gap-[30px]">

				{/* Card 1: Florarium — no badge */}
				<div class="relative w-full">
					<MasterclassCard
						title="Створення флораріуму<br/>в скляній вазі"
						link="/stvorennya-florariumu"
						image="/images/masterclass/florarium-product.webp"
						imageAlt="Флораріум у скляній вазі з мохом та мініатюрними деревами"
						bgImage="/images/masterclass/bg/florarium-bg.webp"
						className="min-h-[515px] md:min-h-0"
					>
						{/* Decorative elements for card 1 */}
						<img src="/images/masterclass/decor-small-leaf.webp" alt="" class="decor-fade absolute left-[31px] bottom-[145px] w-[34px] h-[32px] z-20 pointer-events-none" loading="lazy" />
						<img src="/images/masterclass/decor-leaf-2.webp" alt="" class="decor-fade absolute right-[12.5px] bottom-[121px] w-[29px] h-[29px] z-20 pointer-events-none" style="transition-delay: 0.2s;" loading="lazy" />
						<img src="/images/masterclass/decor-pot-2.webp" alt="" class="decor-fade absolute right-[54.5px] bottom-[18px] w-[70px] h-[80px] z-20 pointer-events-none" style="transition-delay: 0.3s;" loading="lazy" />
						<img src="/images/masterclass/decor-moss-blur.webp" alt="" class="decor-fade absolute right-[43.5px] bottom-[219px] w-[86px] h-[89px] z-20 pointer-events-none" style="filter: blur(3.95px); transition-delay: 0.15s;" loading="lazy" />
					</MasterclassCard>
				</div>

				{/* Card 2: Stabilized plants picture — НОВИНКА */}
				<div class="relative w-full">
					<MasterclassCard
						title="Створення картини<br/>зі стаблізованих рослин"
						link="/kartini-zi-stabilizovanih-roslin"
						image="/images/masterclass/stabilized-art-product-2.webp"
						imageAlt="Картина зі стабілізованих рослин на дерев'яній основі"
						bgImage="/images/masterclass/bg/stabilized-art-bg.webp"
						isNew={true}
						rotateImage={true}
						className="min-h-[525px] md:min-h-0"
					>
						{/* Decorative elements for card 2 */}
						<img src="/images/masterclass/decor-fern-2.webp" alt="" class="decor-fade absolute right-[2.5px] bottom-[289px] w-[77px] h-[65px] z-20 pointer-events-none" loading="lazy" />
						<img src="/images/masterclass/decor-small-moss.webp" alt="" class="decor-fade absolute left-[23px] bottom-[160px] w-[35px] h-[34px] z-20 pointer-events-none" style="transition-delay: 0.2s;" loading="lazy" />
						<img src="/images/masterclass/decor-moss-ball.webp" alt="" class="decor-fade absolute right-[0px] bottom-[40px] w-[70px] h-[63px] z-20 pointer-events-none" style="filter: blur(8px); transition-delay: 0.3s;" loading="lazy" />
					</MasterclassCard>
				</div>

				{/* Card 3: Wreath */}
				<div class="relative w-full md:col-span-2 md:max-w-[50%] md:mx-auto lg:col-span-1 lg:max-w-none">
					<MasterclassCard
						title="Створення вінку<br/>зі стабілізованих рослин"
						link="/vinok-zi-stabilizovanih-roslin"
						image="/images/masterclass/wreath-product-2.webp"
						imageAlt="Вінок зі стабілізованих рослин"
						bgImage="/images/masterclass/bg/wreath-bg.webp"
						isNew={true}
						isComingSoon={false}
						rotateImage={true}
						imageWidth="270px"
						className="min-h-[571px] md:min-h-0"
					>
						{/* Decorative elements for card 3 */}
						<img src="/images/masterclass/decor-leaf-3.webp" alt="" class="decor-fade absolute left-[70%] bottom-[333px] w-[62px] h-[62px] z-20 pointer-events-none" loading="lazy" />
						<img src="/images/masterclass/decor-branch-1.webp" alt="" class="decor-fade absolute right-[40%] bottom-[61px] w-[60px] h-[60px] z-20 pointer-events-none" style="transition-delay: 0.2s;" loading="lazy" />
					</MasterclassCard>
				</div>

			</div>
		</section>

		<AboutSection />

		<StatsSection />

		<section id="faq" class="bg-white px-[9.75px] pt-[6px] pb-[24px] md:px-8 md:pb-[40px] lg:pb-[56px]">
			<div class="mb-[14px] px-[9.75px] md:px-0 max-w-[1280px] mx-auto reveal">
				<Image
					src={faqBanner}
					alt="Питання та відповіді"
					class="w-full h-auto md:max-w-[538px] lg:max-w-[672px] md:mx-auto"
					loading="lazy"
				/>
			</div>
			<FaqAccordion faqs={mainPageFaqs} />
		</section>
	</main>
	<Footer />
</Layout>
