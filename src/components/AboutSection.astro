---
// About section — ІНФОРМАЦІЯ ПРО МЕНЕ
import { Image } from 'astro:assets';
import dariaPhoto from '../assets/about/daria-photo.webp';
import aboutBanner from '../assets/about/header-banner.webp';
---

<section id="about" class="bg-white about-section lg:pb-[40px]">

  {/* ===== Header banner — mobile: full width, md+: centered ===== */}
  <div class="px-[19.25px] pt-[20px] pb-[6px] max-w-[1280px] mx-auto md:px-8 md:flex md:justify-center reveal">
    <Image
      src={aboutBanner}
      alt="Інформація про мене"
      class="w-full h-auto md:max-w-[400px] lg:max-w-[680px]"
      loading="lazy"
    />
  </div>

  {/* ===== Content: text + photo — stacked on mobile, side-by-side on md+ ===== */}
  <div class="md:flex md:items-center md:gap-8 lg:gap-16 max-w-[1280px] mx-auto px-[24px] md:px-8">

    {/* ===== Bio text (left column — 60% on md+) ===== */}
    <div class="pt-[20px] pb-[6px] relative overflow-hidden md:w-[60%] md:pt-[28px] lg:pt-[36px]">

      <p class="font-heading text-[22px] leading-[30px] text-black mb-[18px] md:text-[26px] md:leading-[34px] lg:text-[28px] lg:leading-[36px] reveal">Привіт! Мене звати Даша.</p>
      <p class="text-[16px] leading-[25px] text-black mb-[16px] md:text-[17px] md:leading-[27px] md:text-justify lg:text-[18px] lg:leading-[28px] reveal">Я — майстер-флорист, ботанік і викладач, засновниця майстерні декору Floralab.</p>
      <p class="text-[16px] leading-[25px] text-black mb-[16px] md:text-[17px] md:leading-[27px] md:text-justify lg:text-[18px] lg:leading-[28px] reveal">Моя пристрасть — створення флораріумів і композицій із сукулентів. Уже багато років я поєдную творчість і науку, допомагаючи людям відчути красу живої природи у власному просторі.</p>
      <p class="text-[16px] leading-[25px] text-black mb-[16px] md:text-[17px] md:leading-[27px] md:text-justify lg:text-[18px] lg:leading-[28px] reveal">У Floralab я проводжу майстер-класи, ділюся знаннями, консультую з догляду за рослинами та створюю унікальні рослинні композиції.</p>
      <p class="text-[16px] leading-[25px] text-black md:text-[17px] md:leading-[27px] md:text-justify lg:text-[18px] lg:leading-[28px] reveal">Я постійно вчуся новому й із задоволенням передаю досвід іншим.</p>
    </div>

    {/* ===== Photo (badges ФЛОРИСТ + ДАР'Я КОВАЛЬОВА are part of the image) ===== */}
    <div class="relative mt-[14px] pb-[6px] md:w-[40%] md:mt-0 reveal">

      {/* Cookie ball — slides in from left edge */}
      <img
        src="/images/about/decor-ball.webp"
        alt=""
        class="absolute left-[18px] top-[25px] w-[44px] md:w-[64px] z-10 pointer-events-none cookie-decor md:left-[10px]"
        style="filter: brightness(100%) contrast(100%) saturate(75%) blur(5px);"
        loading="lazy"
      />

      <div class="px-[9.75px] md:px-0">
        <Image
          src={dariaPhoto}
          alt="Дар'я Ковальова — флорист"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>

    </div>

  </div>

</section>

<style>
  .about-section {
    background-image: url('/images/about/about-bg-plants.webp');
    background-position: 0 130px;
    background-size: contain;
    background-repeat: no-repeat;
  }
  @media (min-width: 768px) {
    .about-section {
      background-image: url('/images/about/about-bg-plants.webp');
      background-position: -5% 60px;
      background-size: 110%;
      background-repeat: no-repeat;
    }
  }
  @media (min-width: 1024px) {
    .about-section {
      background-image: url('/images/about/about-bg-desktop.webp');
      background-position: -104px -94px;
      background-size: 110%;
    }
  }

  .cookie-decor {
    opacity: 0;
    transform: translateX(-60px);
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.5s ease-out;
  }
  .cookie-decor.cookie-visible {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie-decor { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  function initCookie() {
    const cookie = document.querySelector<HTMLElement>('.cookie-decor');
    if (!cookie) return;
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('cookie-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0 });
    obs.observe(cookie);
  }
  document.addEventListener('astro:page-load', initCookie);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCookie);
  } else {
    requestAnimationFrame(() => requestAnimationFrame(initCookie));
  }
</script>
