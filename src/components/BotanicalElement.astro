---
interface Props {
  src?: string;
  top?: string;
  bottom?: string;
  left?: string;
  right?: string;
  size?: string;
  blur?: string;
  opacity?: string;
  zIndex?: string;
  className?: string;
  animate?: boolean;
  animationType?: 'float' | 'slide-in';
  delay?: string;
  filter?: string;
  slideX?: string;
  slideY?: string;
  rotation?: string;
}

const {
  src,
  top,
  bottom,
  left,
  right,
  size = "w-24 h-24",
  blur = "",
  opacity = "opacity-100",
  zIndex = "z-10",
  className = "",
  animate = true,
  animationType = 'float',
  delay = "0s",
  filter = "",
  slideX = "0px",
  slideY = "0px",
  rotation = "0deg"
} = Astro.props;

// Construct style string
let styleString = "";
if (top) styleString += `top: ${top}; `;
if (bottom) styleString += `bottom: ${bottom}; `;
if (left) styleString += `left: ${left}; `;
if (right) styleString += `right: ${right}; `;
if (filter) styleString += `filter: ${filter}; `;
styleString += `animation-delay: ${delay}; `;
styleString += `--slide-x: ${slideX}; `;
styleString += `--slide-y: ${slideY}; `;
styleString += `--initial-rotate: ${rotation}; `;

// If it's a slide-in animation, it should start at opacity 0
if (animate && animationType === 'slide-in') {
  styleString += "opacity: 0; ";
}
---

<div 
  class={`botanical-element absolute ${size} ${blur} ${opacity} ${zIndex} ${animate ? (animationType === 'float' ? 'animate-float' : 'slide-in-element') : ''} pointer-events-none ${className}`}
  style={styleString}
>
  {src && <img src={src} alt="" class="w-full h-full object-contain" />}
</div>

<style>
  @keyframes slide-in-new {
    from {
      opacity: 0;
      transform: translate(var(--slide-x, 0), var(--slide-y, 0)) rotate(var(--initial-rotate, 0deg));
    }
    to {
      opacity: 1;
      transform: translate(0, 0) rotate(var(--initial-rotate, 0deg));
    }
  }

  /* Target both the section active state and the container active state */
  :global(.active) .slide-in-element,
  :global(.active).slide-in-element {
    animation: slide-in-new 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
  }

  @keyframes float-new {
    0%, 100% { transform: translateY(0) rotate(var(--initial-rotate, 0deg)); }
    50% { transform: translateY(-10px) rotate(var(--initial-rotate, 0deg)); }
  }

  .animate-float {
    animation: float-new 6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .slide-in-element {
      animation: none !important;
      opacity: 1 !important;
    }
    .animate-float {
      animation: none !important;
    }
  }
</style>
