---
interface Props {
  title: string;
  link: string;
  image: string;
  imageAlt: string;
  bgImage: string;
  isNew?: boolean;
  isComingSoon?: boolean;
  rotateImage?: boolean;
  imageWidth?: string;
  className?: string;
}

const {
  title,
  link,
  image,
  imageAlt,
  bgImage,
  isNew = false,
  isComingSoon = false,
  rotateImage = false,
  imageWidth,
  className = "",
} = Astro.props;

const ribbonBg = isComingSoon ? "#888" : "#f3237d";
const ribbonShadowColor = isComingSoon ? "#555" : "#d10d62";
const ribbonText = isComingSoon ? "СКОРО" : "НОВИНКА";
const showRibbon = isNew || isComingSoon;
const comingSoonClass = isComingSoon ? "card-coming-soon" : "";
---

{/* Outer wrapper: animation target — ribbon + card slide together */}
<div class={`card-reveal-wrapper relative ${className}`}>

  {/* Ribbon badge — inside wrapper so it slides with the card */}
  {showRibbon && (
    <div class="absolute top-0 right-0 z-40 w-[110px] h-[110px] overflow-hidden pointer-events-none" style="scale: 1.18;">
      {/* Corner fold squares */}
      <div
        class="absolute bottom-0 right-0 w-[8px] h-[10px]"
        style={`background: ${ribbonShadowColor}; box-shadow: -101px -102px 0px 0px ${ribbonShadowColor};`}
      >
      </div>
      {/* Diagonal ribbon band */}
      <div class="absolute flex items-center justify-center" style="width: 136.5px; height: 136.5px; left: -2.63px; top: -23.84px;">
        <div class="rotate-45">
          <div class="flex items-center justify-center h-[28px] w-[165px]" style={`background: ${ribbonBg}; box-shadow: 0px 5px 10px 0px rgba(0,0,0,0.1);`}>
            <span class="font-heading text-white text-[11px] text-center tracking-[1.1px] leading-[24px]">
              {ribbonText}
            </span>
          </div>
        </div>
      </div>
    </div>
  )}

  {/* Card body — overflow-hidden for rounded bg */}
  <div class="rounded-[40px] overflow-hidden">
    {/* Inner wrapper handles grayscale for coming soon */}
    <div class={`masterclass-card relative ${comingSoonClass}`}>

      {/* Background image (no blur — matching original site) */}
      <div class="absolute inset-0 pointer-events-none overflow-hidden rounded-[40px]">
        <img
          src={bgImage}
          alt=""
          class="absolute top-0 left-0 w-[115%] h-full object-cover"
          style="transform: scale(1.02);"
          loading="lazy"
        />
      </div>

      {/* Green-to-yellow gradient overlay at 15% opacity */}
      <div
        class="absolute inset-0 rounded-[40px] pointer-events-none"
        style="background: linear-gradient(140deg, rgb(126, 180, 35) 0%, rgb(255, 234, 154) 100%); opacity: 0.15;"
      >
      </div>

      {/* Content layer — fills card height, image pushed to bottom */}
      <div class="relative z-10 flex flex-col items-center pt-[53px] pb-[50px]">
        {/* Title */}
        <div class="text-center px-6">
          <h3
            class="font-heading text-[25px] leading-[35px] tracking-[-0.375px] text-black"
            set:html={title}
          />
        </div>

        {/* Details button */}
        <div class="mt-[21px] mb-[10px]">
          {isComingSoon ? (
            <span
              class="inline-flex items-center justify-center px-[25px] py-[12px] bg-gray-400 text-white rounded-full font-heading text-[22px] leading-[24px] cursor-not-allowed"
              style="box-shadow: 0 10px 25px rgba(0,0,0,0.1);"
            >
              Деталі
            </span>
          ) : (
            <a
              href={link}
              class="inline-flex items-center justify-center px-[25px] py-[12px] bg-[#7cab06] text-white rounded-full font-heading text-[22px] leading-[24px] hover:bg-[#6d9a05] hover:scale-105 active:scale-95 transition-all"
              style="box-shadow: 0 10px 25px rgba(124, 171, 6, 0.25);"
            >
              Деталі
            </a>
          )}
        </div>

        {/* Product image — fades in + scales up when it enters viewport */}
        <div class="flex items-center justify-center px-4 mt-[20px] product-image-wrapper">
          <img
            src={image}
            alt={imageAlt}
            class={`h-auto object-contain product-image-scale ${rotateImage ? "product-rotated" : ""}`}
            style={rotateImage
              ? `width: ${imageWidth ?? "250px"}; filter: drop-shadow(0 8px 16px rgba(0,0,0,0.15));`
              : `width: ${imageWidth ?? "240px"}; filter: drop-shadow(0 8px 16px rgba(0,0,0,0.1));`}
            loading="lazy"
          />
        </div>
      </div>

      {/* Slot for decorative elements */}
      <slot />
    </div>
  </div>
</div>

<style>
  /* ===== Coming Soon (grayscale) ===== */
  .card-coming-soon {
    filter: grayscale(100%) contrast(1.1);
    opacity: 0.85;
  }

  /* ===== Card slide-in — animation on the wrapper so ribbon travels with card ===== */
  @keyframes card-slide-in {
    from {
      transform: translateX(-50px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .card-reveal-wrapper {
    opacity: 0;
    transform: translateX(-50px);
  }
  .card-reveal-wrapper.visible {
    animation: card-slide-in 0.5s ease-out forwards;
  }

  /* ===== Product image: fade-in (50%→100%) + scale, triggered when image enters viewport ===== */
  .product-image-scale {
    transform: scale(0.8);
    opacity: 0.5;
    transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .product-image-scale.product-rotated {
    transform: scale(0.8) rotate(-23deg);
  }
  .product-image-scale.image-visible {
    transform: scale(1);
    opacity: 1;
  }
  .product-image-scale.product-rotated.image-visible {
    transform: scale(1) rotate(-23deg);
  }

  /* ===== Decorative elements fade in (tied to card wrapper) ===== */
  :global(.decor-fade) {
    opacity: 0;
    transition: opacity 0.6s ease-out;
  }
  :global(.card-reveal-wrapper.visible .decor-fade) {
    opacity: 1;
  }

  /* ===== Respect reduced motion ===== */
  @media (prefers-reduced-motion: reduce) {
    .card-reveal-wrapper {
      transform: none;
      opacity: 1;
      animation: none;
    }
    .product-image-scale {
      transform: none !important;
      opacity: 1 !important;
      transition: none;
    }
    .product-image-scale.product-rotated {
      transform: rotate(-23deg) !important;
    }
    :global(.decor-fade) {
      opacity: 1;
      transition: none;
    }
  }
</style>

<script>
  function initCardAnimations() {
    // === Card slide observer ===
    // Uses @keyframes animation (not CSS transition) so it always plays,
    // even for cards already in viewport on page load
    const wrappers = document.querySelectorAll<HTMLElement>('.card-reveal-wrapper:not(.visible)');
    if (wrappers.length > 0) {
      const cardObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const wrapper = entry.target as HTMLElement;
              const allWrappers = document.querySelectorAll('.card-reveal-wrapper');
              const index = Array.from(allWrappers).indexOf(wrapper);

              setTimeout(() => {
                wrapper.classList.add('visible');
              }, 100 + index * 120);

              cardObserver.unobserve(wrapper);
            }
          });
        },
        { threshold: 0, rootMargin: '0px 0px -100px 0px' }
      );
      wrappers.forEach((w) => cardObserver.observe(w));
    }

    // === Product image observer ===
    // Triggers as soon as the image's own edge enters the viewport — fade + scale start together
    const images = document.querySelectorAll<HTMLElement>('.product-image-scale:not(.image-visible)');
    if (images.length > 0) {
      const imageObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('image-visible');
              imageObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: '0px 0px -100px 0px' }
      );
      images.forEach((img: HTMLElement) => imageObserver.observe(img));
    }
  }

  document.addEventListener('astro:page-load', initCardAnimations);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCardAnimations);
  } else {
    initCardAnimations();
  }
</script>
