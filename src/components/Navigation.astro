---
interface Props {
  className?: string;
  currentPath?: string;
  purchaseUrl?: string;
  purchaseLabel?: string;
}

const { className = "", currentPath = "/", purchaseUrl, purchaseLabel = "Придбати навчання" } = Astro.props;

function isActive(href: string): string {
  if (href.startsWith('#')) return '';
  return currentPath === href ? 'text-brand-lime font-bold' : '';
}
---

<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-[#003B1C] focus:text-white focus:rounded-lg focus:font-heading focus:shadow-lg"
>
  Перейти до основного змісту
</a>

<header class={`sticky top-0 z-50 bg-white border-b border-slate-100 lg:top-[20px] lg:mx-auto lg:max-w-[1381px] lg:border lg:border-slate-100 lg:rounded-full lg:shadow-sm ${className}`}>
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 h-16 lg:h-[90px] flex items-center justify-between">
    <a href="/" class="flex items-center group">
      <img src="/images/logo-flora-edu.webp" alt="Floralab Education" class="h-8 md:h-10 w-auto object-contain" />
    </a>

    <button id="mobile-menu-toggle" class="p-2 lg:hidden flex flex-col gap-[5px] items-end group" aria-label="Toggle Menu" aria-expanded="false">
      <span class="w-6 h-[2px] bg-[#003B1C] rounded-full transition-all"></span>
      <span class="w-4 h-[2px] bg-[#003B1C] rounded-full transition-all"></span>
      <span class="w-6 h-[2px] bg-[#003B1C] rounded-full transition-all"></span>
    </button>

    <div class="hidden lg:flex items-center gap-8">
      <nav class="flex items-center gap-8">
        <a href="/" class={`text-sm font-medium hover:text-brand-lime transition-colors ${isActive('/') || 'text-brand-dark'}`}>Головна</a>
        <a href="/stvorennya-florariumu" class={`text-sm font-medium hover:text-brand-lime transition-colors ${isActive('/stvorennya-florariumu') || 'text-brand-dark'}`}>Створення флораріуму</a>
        <a href="/kartini-zi-stabilizovanih-roslin" class={`text-sm font-medium hover:text-brand-lime transition-colors ${isActive('/kartini-zi-stabilizovanih-roslin') || 'text-brand-dark'}`}>Створення картини</a>
        <a href="/vinok-zi-stabilizovanih-roslin" class={`text-sm font-medium hover:text-brand-lime transition-colors ${isActive('/vinok-zi-stabilizovanih-roslin') || 'text-brand-dark'}`}>Створення вінка</a>
        <a href="#about" class="text-sm font-medium text-brand-dark hover:text-brand-lime transition-colors">Про мене</a>
      </nav>
      <div class="flex items-center gap-4 ml-4">
        <a href="https://www.instagram.com/floralab_ua" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-brand-dark hover:text-brand-lime transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://t.me/kam4633" target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="text-brand-dark hover:text-brand-lime transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.7 8c-.12.56-.46.7-.93.44l-2.57-1.9-1.24 1.2c-.14.14-.25.25-.5.25l.18-2.6 4.7-4.24c.2-.18-.04-.28-.32-.1L7.46 14.55 4.93 13.8c-.56-.17-.57-.56.12-.83l8.95-3.45c.47-.17.88.11.64.28z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-white z-[60] flex flex-col -translate-x-full transition-transform duration-300 lg:hidden overflow-y-auto">
    <div class="h-16 flex justify-between items-center px-4">
      <a href="/" class="flex items-center">
        <img src="/images/logo-flora-edu.webp" alt="Floralab Education" class="h-8 w-auto object-contain" />
      </a>
      <button id="mobile-menu-close" class="p-2 text-brand-dark hover:text-brand-pink transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex flex-col gap-6 text-left text-2xl font-heading text-brand-dark px-6 mt-8">
      <a href="/" class={`hover:text-brand-lime transition-colors py-2 ${isActive('/')}`}>Головна</a>
      <a href="/stvorennya-florariumu" class={`hover:text-brand-lime transition-colors py-2 ${isActive('/stvorennya-florariumu')}`}>Створення флораріуму</a>
      <a href="/kartini-zi-stabilizovanih-roslin" class={`hover:text-brand-lime transition-colors py-2 ${isActive('/kartini-zi-stabilizovanih-roslin')}`}>Створення картини</a>
      <a href="/vinok-zi-stabilizovanih-roslin" class={`hover:text-brand-lime transition-colors py-2 ${isActive('/vinok-zi-stabilizovanih-roslin')}`}>Створення вінка</a>
      <a href="#about" class="hover:text-brand-lime transition-colors py-2">Про мене</a>
    </div>

    {purchaseUrl && (
      <div class="mt-12 px-6">
        <a href={purchaseUrl} class="block w-full py-4 bg-[#E63380] text-white rounded-full font-bold shadow-xl shadow-brand-pink/30 hover:scale-[1.02] transition-transform text-center">
          {purchaseLabel}
        </a>
      </div>
    )}
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const close = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu && close) {
    toggle.addEventListener('click', () => {
      menu.classList.remove('-translate-x-full');
      document.body.style.overflow = 'hidden';
      toggle.setAttribute('aria-expanded', 'true');
    });

    close.addEventListener('click', () => {
      menu.classList.add('-translate-x-full');
      document.body.style.overflow = '';
      toggle.setAttribute('aria-expanded', 'false');
    });

    // Close on link click
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('-translate-x-full');
        document.body.style.overflow = '';
        toggle.setAttribute('aria-expanded', 'false');
      });
    });

    // Reset mobile menu on resize to desktop
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) {
        menu.classList.add('-translate-x-full');
        document.body.style.overflow = '';
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
