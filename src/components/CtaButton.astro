---
interface Props {
  text?: string;
  href?: string;
  course?: string;
}
const { text = 'Хочу на майстер-клас', href = '#pricing', course } = Astro.props;
---

<div class="flex justify-center py-[32px] bg-white reveal">
  <a
    href={href}
    data-cta-scroll
    data-course={course}
    class="inline-flex items-center justify-center font-heading text-white font-medium hover:scale-[1.02] transition-transform"
    style="padding: 16px 40px; background: #c91e6b; border-radius: 100px; font-size: 20px;"
  >
    {text}
  </a>
</div>
