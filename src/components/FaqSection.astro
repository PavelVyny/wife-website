---
import FaqAccordion from './FaqAccordion.astro';

interface Props {
  titleImage: string;
  titleImageAlt?: string;
  faqs: Array<{ q: string; a: string[] }>;
  decorTopRight?: { src: string; style: string };
  decorBottomLeft?: { src: string; style: string };
}
const { titleImage, titleImageAlt = 'Питання та відповідь', faqs, decorTopRight, decorBottomLeft } = Astro.props;
---

<section id="faq" class="relative bg-white px-[10px] py-[40px] md:px-8 md:py-[56px] lg:py-[48px] overflow-hidden">
  {decorTopRight && (
    <img src={decorTopRight.src} alt="" width="200" height="200"
      class="hidden lg:block absolute pointer-events-none z-0"
      style={decorTopRight.style} />
  )}
  {decorBottomLeft && (
    <img src={decorBottomLeft.src} alt="" width="160" height="180"
      class="hidden lg:block absolute pointer-events-none z-0 decor-anim"
      style={decorBottomLeft.style} />
  )}
  <div class="max-w-[1280px] mx-auto">
    <div class="flex justify-center mb-[20px] reveal">
      <img
        src={titleImage}
        alt={titleImageAlt}
        width="1024"
        height="460"
        class="w-full max-w-[280px] md:max-w-[380px] lg:max-w-[420px] h-auto"
        loading="lazy"
      />
    </div>
    <FaqAccordion faqs={faqs} />
  </div>
</section>
