---
// ValueProps — responsive 3-card grid of value propositions
// Accepts card data via props so each masterclass page can define its own content

interface Props {
  cards: Array<{
    title: string;
    description: string;
    icon?: string;
  }>;
}

const { cards } = Astro.props;
---

<section id="value-props" class="bg-white px-[24px] pt-[20px] pb-[24px] md:px-8 md:pt-[32px] md:pb-[40px] lg:pb-[56px]">
  <div class="max-w-[1280px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[16px] md:gap-[24px]">
      {cards.map((card) => (
        <div class="bg-white border border-[#003B1C]/10 rounded-[28px] p-[24px] md:p-[32px] shadow-sm hover:shadow-md transition-shadow reveal">
          {card.icon && (
            <div class="text-[32px] mb-[12px]">{card.icon}</div>
          )}
          <h3 class="font-heading text-brand-dark text-[20px] md:text-[22px] leading-[1.3] mb-[12px]">
            {card.title}
          </h3>
          <p class="text-brand-dark/60 text-[15px] leading-[24px]">
            {card.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
