---
// ValueProps — responsive grid of value propositions with memoji images and numbered badges
// Matches original site layout: centered image, title, description, numbered badge

interface Props {
  cards: Array<{
    title: string;
    description: string;
    icon?: string;
    image?: string;
  }>;
}

const { cards } = Astro.props;
---

<section id="value-props" class="bg-white px-[10px] pt-[40px] pb-[40px] md:px-8 md:pt-[56px] md:pb-[56px] lg:pb-[72px]">
  <div class="max-w-[1280px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-[20px] lg:gap-[24px]">
      {cards.map((card, i) => (
        <div
          class="relative text-center px-[16px] py-[32px] md:p-[32px] reveal"
          style={`transition-delay: ${i * 0.15}s`}
        >
          {/* Numbered badge */}
          <div class="hidden lg:flex absolute top-[8px] left-[16px] w-[42px] h-[42px] rounded-full items-center justify-center text-white font-heading text-[24px]" style="background: #00401e;">
            {i + 1}
          </div>

          {/* Memoji image */}
          {card.image && (
            <div class="flex justify-center mb-[16px]">
              <img
                src={card.image}
                alt={card.title}
                width="228"
                height="228"
                class="w-[180px] h-[180px] md:w-[200px] md:h-[200px] object-contain"
                loading="lazy"
              />
            </div>
          )}

          <h3 class="font-heading text-black text-[24px] md:text-[29px] leading-[1.3] mb-[12px]">
            {card.title}
          </h3>
          <p class="text-[#8a8a8a] text-[16px] leading-[24px]">
            {card.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

