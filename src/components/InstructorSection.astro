---
// InstructorSection — Daria's credentials, shared across all masterclass pages
---

<section id="about" class="relative bg-white px-[10px] pt-[20px] pb-[40px] md:px-8 md:pt-[40px] md:pb-[56px] lg:pt-[56px] lg:pb-[72px] overflow-hidden scroll-mt-[20px]"
  style="background-image: url('/images/masterclass/about-bg.webp'); background-position: 50% 100px; background-size: 100% auto; background-repeat: no-repeat;">

  <style>
    @media (min-width: 1024px) {
      #about {
        background-image: none !important;
      }
    }
  </style>
  {/* Gradient fade from previous section */}
  <div class="absolute top-0 left-0 right-0 h-[60px] pointer-events-none z-0" style="background: linear-gradient(to bottom, #f8f8f8, transparent);"></div>

  <div class="max-w-[1280px] mx-auto">

    {/* Title image */}
    <div class="flex justify-center mb-[16px] md:mb-[24px] reveal">
      <img
        src="/images/masterclass/about-title.webp"
        alt="Інформація про мене"
        width="1024"
        height="460"
        class="w-full max-w-[320px] md:max-w-[420px] lg:max-w-[460px] h-auto"
        loading="lazy"
      />
    </div>

    <div class="lg:grid lg:grid-cols-2 lg:gap-[48px] lg:items-center">

      {/* Photo — top on mobile, left column on desktop */}
      <div class="mb-[24px] lg:mb-0 reveal">
        <div class="relative mx-auto">
          {/* Star-eyes emoji decoration — top-right of photo */}
          <span class="absolute top-[-10px] right-[16%] text-[48px] z-10 decor-sway" style="--dur: 3s; --del: 0s;">🤩</span>
          <img
            src="/images/masterclass/about-daria-portrait.webp"
            alt="Дар'я Ковальова — засновниця Floralab"
            width="1024"
            height="1024"
            class="w-full object-contain"
            loading="lazy"
          />
        </div>
      </div>

      {/* Text content — below photo on mobile, right column on desktop */}
      <div class="reveal">
        <ul class="space-y-[20px] px-[14px] md:px-0 mb-[24px]">
          {[
            "Майстер-флорист, ботанік, викладач",
            "Засновниця майстерні декору Floralab",
            "Провела понад 60 успішних майстер-класів і створила більше 500 флораріумів",
            "Більше 5 років досвіду роботи з сукулентами та флораріумами",
            "4 роки консультую, проводжу майстер-класи та створюю композиції з сукулентів",
            "Завжди вчуся та щедро ділюся знаннями з іншими",
          ].map((item) => (
            <li class="text-black text-[18px] leading-[28px] flex gap-[12px] items-center font-heading font-medium">
              <span class="flex-shrink-0 w-[28px] h-[28px] rounded-full flex items-center justify-center" style="background: #7fac00;">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>

      </div>

    </div>

    {/* Quote banner image — below photo + list */}
    <div class="reveal mt-[40px] px-[14px] md:px-0 lg:hidden">
      <img
        src="/images/masterclass/about-quote-banner.webp"
        alt="Я переконана, що творчий потенціал закладений у кожному з нас"
        width="1024"
        height="525"
        class="w-full lg:max-w-[700px] h-auto"
        loading="lazy"
      />
    </div>
  </div>
</section>
