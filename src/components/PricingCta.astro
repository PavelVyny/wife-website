---
// PricingCta — pricing section with strikethrough price, motivational text, and pink Buy Now CTA
import SectionHeader from './SectionHeader.astro';

interface Props {
  price: string;
  originalPrice?: string;
  ctaText: string;
  purchaseUrl: string;
  motivationalText?: string;
}

const { price, originalPrice, ctaText, purchaseUrl, motivationalText } = Astro.props;
---

<section id="pricing" class="bg-white px-[24px] py-[40px] md:px-8 md:py-[56px] lg:py-[72px]">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex justify-center mb-[32px] md:mb-[40px] reveal">
      <SectionHeader mainTitle="Вартість" accentTitle="Та доступ" />
    </div>

    <div class="lg:grid lg:grid-cols-2 lg:gap-[48px] lg:items-center reveal">
      {/* Motivational text — left column on desktop */}
      <div class="mb-[32px] lg:mb-0">
        {motivationalText ? (
          <div class="bg-[#003B1C] rounded-[20px] p-[24px] md:p-[32px]">
            <p class="text-white/90 text-[16px] md:text-[18px] leading-[28px] italic">
              {motivationalText}
            </p>
          </div>
        ) : (
          <div class="bg-[#003B1C] rounded-[20px] p-[24px] md:p-[32px]">
            <p class="text-white/90 text-[16px] md:text-[18px] leading-[28px] italic">
              Забудь про штучний декор з магазинів! Замовляй майстер-клас вже сьогодні та створи унікальний виріб, який стане родзинкою твого інтер'єру.
            </p>
          </div>
        )}
      </div>

      {/* Price + CTA — right column */}
      <div class="text-center lg:text-left">
        <div class="mb-[16px]">
          {originalPrice && (
            <span class="text-brand-dark/40 line-through text-[20px] mr-[12px]">{originalPrice}</span>
          )}
          <span class="font-heading text-[#E63380] text-[42px] md:text-[56px]">{price}</span>
        </div>

        <p class="text-[#7cab06] font-heading text-[16px] mb-[20px]">
          Акційна пропозиція обмежена
        </p>

        <a
          href={purchaseUrl}
          class="inline-flex px-[40px] py-[16px] bg-[#E63380] text-white rounded-full font-heading text-[20px] md:text-[22px] hover:scale-[1.02] transition-transform mb-[24px]"
          style="box-shadow: 0 10px 30px rgba(230,51,128,0.4);"
        >
          {ctaText}
        </a>

        <div class="space-y-[8px] mt-[16px]">
          <p class="text-brand-dark/70 text-[15px] leading-[24px] flex items-center gap-[8px] justify-center lg:justify-start">
            <span class="text-[#7cab06]">✓</span> Акційна пропозиція обмежена в часі
          </p>
          <p class="text-brand-dark/70 text-[15px] leading-[24px] flex items-center gap-[8px] justify-center lg:justify-start">
            <span class="text-[#7cab06]">✓</span> Доступ до відеоуроків не обмежений
          </p>
          <p class="text-brand-dark/70 text-[15px] leading-[24px] flex items-center gap-[8px] justify-center lg:justify-start">
            <span class="text-[#7cab06]">✓</span> Майстер-клас доступний в Telegram одразу після оплати
          </p>
        </div>
      </div>
    </div>

  </div>
</section>
