---
import BotanicalElement from "./BotanicalElement.astro";
import { Image } from 'astro:assets';
import dariaWithFlower from '../assets/hero/Daria-with-flower.webp';
import starIcon from '../assets/hero/star_2b50.webp';

interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
  imageAlt: string;
}

const { title, subtitle, ctaText, ctaLink, imageAlt } = Astro.props;
---

<section
  class="relative z-[1] h-[calc(100svh-64px-25px)] flex flex-col justify-start bg-brand-cream/30 pt-0 pb-0 md:pt-0 lg:pt-0 rounded-b-[25px] overflow-hidden"
>
  {/* Background Image - Clipped by rounded corners */}
  <div
    class="absolute inset-x-0 top-0 bottom-0 z-0 text-brand-dark/30 rounded-b-[25px] overflow-hidden"
  >
    {/* Mobile background */}
    <img
      src="/images/hero-bg-moss.webp"
      alt=""
      class="w-full h-full object-cover md:hidden"
    />
    {/* Desktop background */}
    <img
      src="/images/hero-bg-desktop.webp"
      alt=""
      class="w-full h-full object-cover hidden md:block"
    />
  </div>

  {/* Floating Decorative Elements - Not clipped, allowing bleed */}
  <div
    id="hero-deco-container"
    class="absolute inset-x-0 top-0 bottom-0 z-10 pointer-events-none"
  >
    {/* Top Left: Moss (blurred) - Slides from top-left edge */}
    <BotanicalElement
      src="/images/moss-small-1.webp"
      top="15%"
      left="7%"
      size="w-[35px] md:w-[80px] lg:w-[120px] h-auto"
      rotation="-131deg"
      opacity="opacity-80"
      filter="brightness(103%) contrast(100%) saturate(71%) blur(4px) hue-rotate(0deg)"
      animationType="slide-in"
      delay="0s"
      slideX="-120px"
      slideY="-100px"
    />

    {/* Top Right: Wood - Slides from top-right edge */}
    <BotanicalElement
      src="/images/wood-1.webp"
      top="16%"
      right="2%"
      size="w-[67px] md:w-[100px] lg:w-[121px] h-auto"
      rotation="0deg"
      opacity="opacity-95"
      animationType="slide-in"
      delay="0.05s"
      slideX="100px"
      slideY="-80px"
    />

    {/* Cookie - Slides from left edge */}
    <BotanicalElement
      src="/images/cookie-1.webp"
      top="55%"
      left="-1%"
      size="w-[41px] md:w-[50px] lg:w-[69px] h-auto"
      rotation="15deg"
      opacity="opacity-100"
      animationType="slide-in"
      delay="0.05s"
      slideX="-80px"
      slideY="20px"
      filter="brightness(100%) contrast(100%) saturate(75%) blur(0) hue-rotate(0deg)"
    />

    {/* Large wood branch — fills empty top-center space on md+ */}
    <BotanicalElement
      src="/images/wood-1.webp"
      top="5%"
      left="38%"
      size="hidden md:block md:w-[110px] lg:w-[155px] h-auto"
      rotation="-25deg"
      opacity="opacity-85"
      animationType="slide-in"
      delay="0.12s"
      slideX="0px"
      slideY="-100px"
    />

    {
      /* Bottom Left Large Flower/Moss: Slides from bottom-left corner */
    }
    <BotanicalElement
      src="/images/moss-small-2.webp"
      bottom="-7%"
      left="8%"
      size="w-[127px] md:w-[200px] lg:w-[259px] h-auto"
      rotation="-10deg"
      opacity="opacity-90"
      filter="brightness(100%) contrast(100%) saturate(75%) blur(5.3px) hue-rotate(0deg)"
      animationType="slide-in"
      delay="0.1s"
      slideX="-60px"
      slideY="100px"
    />

    {/* Right side: Moss - Slides from right edge */}
    <BotanicalElement
      src="/images/moss-small-1.webp"
      bottom="33%"
      right="9%"
      size="w-[49px] md:w-[80px] lg:w-[108px] h-auto"
      blur="blur-none"
      rotation="5deg"
      opacity="opacity-80"
      animationType="slide-in"
      delay="0.15s"
      slideX="100px"
      slideY="60px"
    />
  </div>

  {/* Main content wrapper — stacks on mobile, side-by-side on desktop */}
  <div class="flex-1 min-h-0 flex flex-col md:flex-row md:items-center relative z-20 mt-8 md:mt-0 max-w-[1280px] mx-auto w-full">

    {/* Text content */}
    <div
      class="flex flex-col items-center text-center md:items-start md:text-left md:w-1/2 md:pl-12 lg:pl-20 xl:pl-24 px-4"
    >
      {/* Badge — mobile only */}
      <div
        class="inline-flex md:hidden items-center gap-2 px-[12px] py-[6px] rounded-full bg-[#00401E] border-[0.8px] border-[#00401E] mb-3 slide-down shadow-[0_8px_25px_rgba(0,64,30,0.25)]"
      >
        <Image
          src={starIcon}
          alt="Star"
          class="w-[14px] h-[14px] object-contain"
        />
        <span
          class="text-[14px] font-heading font-medium tracking-[0.4px] text-white leading-[1.4]"
          >Онлайн навчання</span
        >
      </div>

      <h1
        class="text-[32px] md:text-[36px] lg:text-[69px] font-heading text-brand-dark mb-3 md:mb-6 leading-[1.2] md:leading-[1.2] lg:leading-[84px] max-w-lg lg:max-w-[661px] slide-up"
      >
        <span class="relative inline-block">
          Креативні
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 500 150"
            class="absolute -bottom-1 lg:-bottom-3 left-0 w-full h-8 lg:h-14 wpr-highlight-underline-zigzag overflow-visible"
            preserveAspectRatio="none"
          >
            <path
              class="zigzag-path"
              d="M9.3,127.3c49.3-3,150.7-7.6,199.7-7.4c121.9,0.4,189.9,0.4,282.3,7.2C380.1,129.6,181.2,130.6,70,139 c82.6-2.9,254.2-1,335.9,1.3c-56,1.4-137.2-0.3-197.1,9"
              fill="none"
              stroke="#7fac00"
              stroke-width="18"
              stroke-linecap="round"></path>
          </svg>
        </span>
        <br /> Майстер-класи <br class="hidden lg:inline" />від FLORALAB
      </h1>

      <p
        class="text-[16px] lg:text-[24px] font-heading font-medium text-black leading-[1.4] lg:leading-[30px] tracking-[-0.027em] max-w-2xl lg:max-w-[508px] mb-2 slide-up px-4 md:px-0"
      >
        Практичні онлайн <br class="md:hidden" /> майстер-класи для кожного, хто <br
          class="md:hidden"
        /> хоче зануритися у світ природи <br class="md:hidden" /> та ручної роботи
      </p>

      <a
        href={ctaLink}
        class="hidden md:inline-flex items-center justify-center px-[28px] py-[13px] bg-[#7cab06] text-white rounded-full font-heading text-[18px] leading-[24px] hover:bg-[#6d9a05] hover:scale-105 active:scale-95 transition-all slide-up mt-4 mb-2"
        style="box-shadow: 0 10px 25px rgba(124, 171, 6, 0.25);"
      >
        {ctaText}
      </a>

      {/* Arrows — mobile only */}
      <div class="flex flex-col items-center slide-up md:hidden">
        <div class="relative w-11 h-10 flex flex-col items-center justify-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 40 40"
            class="w-full h-full text-brand-dark/30"
          >
            <path
              class="arrow-1"
              d="M12 16L20 21L28 16"
              fill="none"
              stroke="currentColor"
              stroke-width="2.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              class="arrow-2"
              d="M12 25L20 30L28 25"
              fill="none"
              stroke="currentColor"
              stroke-width="2.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
      </div>
    </div>

    {/* Founders photo */}
    <div
      class="hero-photo relative w-full max-w-[340px] md:max-w-none md:w-1/2 mx-auto px-4 slide-up left-[-10px] md:left-0 flex-1 min-h-0 md:self-end overflow-hidden"
    >
      <div class="relative flex justify-center items-end h-full md:h-auto">
        <Image
          src={dariaWithFlower}
          alt="Даша - засновник Floralab"
          class="w-full h-auto max-h-full object-contain relative z-20 block translate-y-[10px] md:translate-y-0 md:max-w-[500px] lg:max-w-[600px] xl:max-w-[699px] mx-auto"
        />
        {/* Decorative Blur behind Daria */}
        <div
          class="absolute bottom-[20%] left-1/2 -translate-x-1/2 w-48 h-48 md:w-64 md:h-64 bg-brand-pink/15 blur-[60px] rounded-full z-10"
        >
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .slide-up {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .slide-up.active {
    opacity: 1;
    transform: translateY(0);
  }

  .slide-down {
    opacity: 0;
    transform: translateY(-20px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .slide-down.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Zilzag animation */
  .zigzag-path {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    opacity: 0;
    transition:
      stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s ease-out;
    transition-delay: 0.5s; /* Start half second after title */
  }

  .slide-up.active .zigzag-path {
    stroke-dashoffset: 0;
    opacity: 1;
  }

  /* Double Arrow Animation */
  .arrow-1,
  .arrow-2 {
    opacity: 0;
    animation: arrow-blink 2.4s infinite;
  }

  .arrow-2 {
    animation-delay: 0.4s;
  }

  @keyframes arrow-blink {
    0% {
      opacity: 0;
      transform: translateY(-4px);
    }
    20%,
    50% {
      opacity: 1;
      transform: translateY(0);
    }
    80%,
    100% {
      opacity: 0;
      transform: translateY(2px);
    }
  }

  /* Hide Daria photo on very short viewports */
  @media (max-height: 480px) {
    .hero-photo {
      display: none;
    }
  }
</style>

<script>
  // Simple intersection observer for animations
  document.addEventListener("DOMContentLoaded", () => {
    // Trigger botanical elements immediately (section is always full-size now)
    setTimeout(() => {
      document.getElementById("hero-deco-container")?.classList.add("active");
    }, 100);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
          }
        });
      },
      { threshold: 0.1 },
    );

    document
      .querySelectorAll(".slide-up, .slide-down")
      .forEach((el) => observer.observe(el));
  });
</script>
