---
interface Props {
  mainTitle: string;
  accentTitle: string;
  className?: string;
}

const { mainTitle, accentTitle, className = "" } = Astro.props;
---

<div class={`relative inline-flex flex-col items-center mb-6 md:mb-12 ${className}`}>
  {/* Lime green top pill — smaller, offset to the right */}
  <div
    class="relative z-10 self-end font-heading text-white uppercase rounded-full tracking-widest text-[11px] md:text-[18px] px-[12px] py-[6px] md:px-[28px] md:py-[10px]"
    style="background: #7cab06; letter-spacing: 0.15em; margin-bottom: -12px; margin-right: 10px;"
  >
    {mainTitle}
  </div>

  {/* Dark green bottom pill — wider, main title */}
  <div
    class="font-heading text-white uppercase rounded-full tracking-widest text-center text-[14px] md:text-[28px] px-[16px] py-[10px] md:px-[40px] md:py-[16px]"
    style="background: #003B1C; letter-spacing: 0.1em;"
  >
    {accentTitle}
  </div>
</div>
