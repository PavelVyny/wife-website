---
interface Props {
  mainTitle: string;
  accentTitle: string;
  className?: string;
}

const { mainTitle, accentTitle, className = "" } = Astro.props;
---

<div class={`relative inline-flex items-center py-4 px-8 mb-12 ${className}`}>
  {/* Overlapping Blob Backgrounds */}
  <div class="absolute inset-0 flex items-center justify-center opacity-80 pointer-events-none">
    <div class="absolute -left-4 w-full h-full bg-brand-dark rounded-full blur-xl scale-x-110 -rotate-2"></div>
    <div class="absolute -right-4 w-full h-full bg-brand-lime rounded-full blur-lg scale-x-105 rotate-1"></div>
  </div>
  
  <div class="relative z-10 flex flex-col items-center text-center">
    <span class="text-white font-heading text-sm sm:text-lg tracking-[0.2em] uppercase leading-none mb-1 translate-y-1">
      {mainTitle}
    </span>
    <span class="text-white font-heading text-2xl sm:text-4xl tracking-wider uppercase leading-none">
      {accentTitle}
    </span>
  </div>
</div>
