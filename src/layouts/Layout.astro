---
import BotanicalElement from '../components/BotanicalElement.astro';
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Мастер-классы и обучение" } = Astro.props;
import '../styles/global.css';
import '@fontsource/tenor-sans';
import tenorSansWoff2 from '@fontsource/tenor-sans/files/tenor-sans-latin-400-normal.woff2?url';
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<!-- Fonts -->
		<link 
			rel="preload" 
			href={tenorSansWoff2} 
			as="font" 
			type="font/woff2" 
			crossorigin
		>
	</head>
	<body class="bg-white text-slate-900 font-sans selection:bg-brand-lime selection:text-white antialiased overflow-x-hidden">
		<slot />

		<button 
			id="scroll-to-top" 
			class="fixed bottom-6 right-6 z-40 p-3 bg-white border border-brand-dark/10 rounded-full shadow-lg text-brand-dark/40 opacity-0 translate-y-4 transition-all duration-300 hover:text-brand-dark hover:scale-110"
			aria-label="Scroll to top"
		>
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
			</svg>
		</button>

		<script>
			// Global reveal animation observer
			function initReveal() {
				const els = document.querySelectorAll<HTMLElement>('.reveal:not(.revealed)');
				if (els.length === 0) return;
				const obs = new IntersectionObserver((entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							(e.target as HTMLElement).classList.add('revealed');
							obs.unobserve(e.target);
						}
					});
				}, { threshold: 0.1 });
				els.forEach((el) => obs.observe(el));
			}
			document.addEventListener('astro:page-load', initReveal);
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initReveal);
			} else {
				requestAnimationFrame(() => requestAnimationFrame(initReveal));
			}

			const scrollBtn = document.getElementById('scroll-to-top');
			if (scrollBtn) {
				window.addEventListener('scroll', () => {
					if (window.scrollY > 300) {
						scrollBtn.classList.remove('opacity-0', 'translate-y-4');
					} else {
						scrollBtn.classList.add('opacity-0', 'translate-y-4');
					}
				});
				scrollBtn.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			}
		</script>
	</body>
</html>

<style is:global>
	:root {
		--brand-dark: #003B1C;
		--brand-lime: #8EC641;
		--brand-pink: #E63380;
		--brand-cream: #FEFDF9;
	}
	
	/* Font override to prevent Layout Shift (CLS) */
	@font-face {
		font-family: 'Tenor Sans Fallback';
		src: local('Times New Roman'), local('serif');
		ascent-override: 90%;
		descent-override: 20%;
		line-gap-override: 0%;
		size-adjust: 105%;
	}

	html {
		scroll-behavior: smooth;
	}
	body, h1, h2, h3, h4, .font-heading {
		font-family: 'Tenor Sans', 'Tenor Sans Fallback', serif !important;
	}

	/* ===== Global reveal animation ===== */
	.reveal {
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}
	@media (prefers-reduced-motion: reduce) {
		.reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>
