---
import BotanicalElement from '../components/BotanicalElement.astro';
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Мастер-классы и обучение" } = Astro.props;
import '../styles/global.css';
import '@fontsource/tenor-sans';
import tenorSansWoff2 from '@fontsource/tenor-sans/files/tenor-sans-latin-400-normal.woff2?url';
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<!-- Fonts -->
		<link
			rel="preload"
			href={tenorSansWoff2}
			as="font"
			type="font/woff2"
			crossorigin
		>
		<!-- Google Analytics 4 — production only -->
		<script is:inline>
		  if (window.location.hostname.endsWith('floralabeducation.com.ua')) {
		    var s = document.createElement('script');
		    s.async = true;
		    s.src = 'https://www.googletagmanager.com/gtag/js?id=G-KEFTVWTZV1';
		    document.head.appendChild(s);
		    window.dataLayer = window.dataLayer || [];
		    function gtag(){dataLayer.push(arguments);}
		    gtag('js', new Date());
		    gtag('config', 'G-KEFTVWTZV1');
		  }
		</script>
		<!-- Microsoft Clarity — production only, TODO: replace ID -->
		<script is:inline type="text/javascript">
		  if (window.location.hostname.endsWith('floralabeducation.com.ua')) {
		    (function(c,l,a,r,i,t,y){
		      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
		      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
		      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
		    })(window, document, "clarity", "script", "w6hf5nplp3");
		  }
		</script>
	</head>
	<body class="bg-white text-slate-900 font-sans selection:bg-brand-lime selection:text-white antialiased">
		<slot />

		<button 
			id="scroll-to-top" 
			class="fixed bottom-6 right-6 z-40 p-3 bg-white/80 backdrop-blur-sm rounded-full shadow-md text-black/50 opacity-0 translate-y-4 transition-[opacity,transform] duration-300 hover:text-black/80 hover:shadow-lg hover:scale-110"
			aria-label="Scroll to top"
		>
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
			</svg>
		</button>

		<script>
			// Global reveal animation observer
			function initReveal() {
				const els = document.querySelectorAll<HTMLElement>('.reveal:not(.revealed)');
				if (els.length === 0) return;
				const obs = new IntersectionObserver((entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							(e.target as HTMLElement).classList.add('revealed');
							obs.unobserve(e.target);
						}
					});
				}, { threshold: 0.01, rootMargin: '0px 0px 200px 0px' });
				els.forEach((el) => obs.observe(el));
			}
			document.addEventListener('astro:page-load', initReveal);
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initReveal);
			} else {
				requestAnimationFrame(() => requestAnimationFrame(initReveal));
			}

			const scrollBtn = document.getElementById('scroll-to-top');
			if (scrollBtn) {
				window.addEventListener('scroll', () => {
					if (window.scrollY > 300) {
						scrollBtn.classList.remove('opacity-0', 'translate-y-4');
					} else {
						scrollBtn.classList.add('opacity-0', 'translate-y-4');
					}
				});
				scrollBtn.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			}
		</script>
	</body>
</html>

<style is:global>
	:root {
		--brand-dark: #003B1C;
		--brand-lime: #8EC641;
		--brand-pink: #E63380;
		--brand-cream: #FEFDF9;
	}
	
	/* Font override to prevent Layout Shift (CLS) */
	@font-face {
		font-family: 'Tenor Sans Fallback';
		src: local('Times New Roman'), local('serif');
		ascent-override: 90%;
		descent-override: 20%;
		line-gap-override: 0%;
		size-adjust: 105%;
	}

	html {
		scroll-behavior: smooth;
		overflow-x: hidden;
		overflow-y: scroll;
	}
	@media (min-width: 1024px) {
		html {
			scrollbar-gutter: stable;
		}
	}
	body, h1, h2, h3, h4, .font-heading {
		font-family: 'Tenor Sans', 'Tenor Sans Fallback', serif !important;
	}

	/* ===== Global reveal animation ===== */
	.reveal {
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}
	@media (prefers-reduced-motion: reduce) {
		.reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}

	/* Accessible focus rings — brand lime green */
	:focus-visible {
		outline: 2px solid #8EC641;
		outline-offset: 2px;
		border-radius: 4px;
	}

	/* Remove default outline on mouse click — only show on keyboard navigation */
	:focus:not(:focus-visible) {
		outline: none;
	}
</style>
